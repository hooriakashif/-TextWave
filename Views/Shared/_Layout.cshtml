<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TextWave</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar navbar-textwave navbar-expand-lg" id="mainNavbar">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand" href="/">
                <i class="fas fa-wave-square me-2" style="font-size:1.4rem;"></i>Text<span>Wave</span>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent"
                    style="border-color:var(--border-color);color:var(--accent-light);">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")"
                           href="/">
                            Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "About" ? "active" : "")"
                           href="/Home/About">
                            About Us
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Pricing" ? "active" : "")"
                           href="/Home/Pricing">
                            Pricing
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Blog" ? "active" : "")"
                           href="/Home/Blog">
                            Blog
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Contact" ? "active" : "")"
                           href="/Home/Contact">
                            Contact
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Privacy" ? "active" : "")"
                           href="/Home/Privacy">
                            Privacy
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Terms" ? "active" : "")"
                           href="/Home/Terms">
                            Terms
                        </a>
                    </li>
                </ul>

                <!-- Auth Buttons -->
                <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <span class="tw-badge">
                            <i class="fas fa-circle" style="font-size:0.5rem;color:#4ade80;"></i>
                            @User.Identity.Name
                        </span>
                        <form asp-area="Identity" asp-page="/Account/Logout"
                              asp-route-returnUrl="/" method="post" class="d-inline">
                            <button type="submit" class="btn-nav-signin nav-link">
                                <i class="fas fa-sign-out-alt me-1"></i> Sign Out
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="/Identity/Account/Login" class="btn-nav-signin nav-link">
                            Sign In
                        </a>
                        <a href="/Identity/Account/Register" class="btn-nav-signup nav-link">
                            Get Started Free
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- ========== MAIN CONTENT ========== -->
    <main>
        @RenderBody()
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="footer-textwave">
        <div class="container">
            <div class="row g-5">

                <!-- Brand Column -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <i class="fas fa-wave-square me-2"></i>TextWave
                    </div>
                    <p class="footer-desc">
                        The world's most reliable bulk SMS platform. Send smarter,
                        reach faster, grow bigger — in 90+ countries.
                    </p>
                    <div class="footer-social mt-4">
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Company</h6>
                    <ul class="footer-links">
                        <li><a href="/Home/About"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> About Us</a></li>
                        <li><a href="/Home/Blog"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Blog</a></li>
                        <li><a href="/Home/Contact"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Contact</a></li>
                        <li><a href="/Home/Pricing"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Pricing</a></li>
                        
                    </ul>
                </div>

                <!-- Legal -->
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Legal</h6>
                    <ul class="footer-links">
                        <li><a href="/Home/Privacy"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Privacy Policy</a></li>
                        <li><a href="/Home/Terms"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Terms & Conditions</a></li>
                    </ul>
                </div>

                <!-- Services -->
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Services</h6>
                    <ul class="footer-links">
                        <li><a href="#"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Bulk SMS</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> OTP SMS</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> SMS API</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> Two-Way SMS</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right" style="font-size:0.7rem;"></i> SMS Campaigns</a></li>
                    </ul>
                </div>

                <!-- Contact Info -->
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Contact</h6>
                    <ul class="footer-links">
                        <li>
                            <a href="mailto:hello@textwave.io">
                                <i class="fas fa-envelope" style="font-size:0.75rem;"></i>
                                hello@textwave.io
                            </a>
                        </li>
                        <li>
                            <a href="tel:+18001234567">
                                <i class="fas fa-phone" style="font-size:0.75rem;"></i>
                                +1 800 123 4567
                            </a>
                        </li>
                        <li>
                            <a href="#">
                                <i class="fas fa-map-marker-alt" style="font-size:0.75rem;"></i>
                                San Francisco, CA
                            </a>
                        </li>
                    </ul>
                </div>

            </div>

            <!-- Footer Bottom -->
            <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <p class="mb-0">
                    &copy; @DateTime.Now.Year <strong style="color:var(--accent-light)">TextWave</strong>.
                    All rights reserved.
                </p>
                <div class="d-flex gap-4">
                    <a href="/Home/Privacy" style="color:var(--gray-text);font-size:0.88rem;">Privacy Policy</a>
                    <a href="/Home/Terms" style="color:var(--gray-text);font-size:0.88rem;">Terms & Conditions</a>
                </div>
                <p class="mb-0" style="font-size:0.85rem;">
                    Made with <i class="fas fa-heart" style="color:var(--accent);"></i> for businesses worldwide
                </p>
            </div>
        </div>
    </footer>

    <!-- ========== BACK TO TOP ========== -->
    <button class="back-to-top" id="backToTop" aria-label="Back to top">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- ========== TOAST CONTAINER ========== -->
    <div id="toastContainer"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Global Scripts -->
    <script>
        // ---- Navbar scroll effect ----
        const navbar = document.getElementById('mainNavbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 50);
        });

        // ---- Back to top ----
        const backToTop = document.getElementById('backToTop');
        window.addEventListener('scroll', () => {
            backToTop.classList.toggle('visible', window.scrollY > 400);
        });
        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // ---- Scroll reveal ----
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    setTimeout(() => entry.target.classList.add('visible'), i * 100);
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        // ---- Toast helper (available globally) ----
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `tw-toast tw-toast-${type}`;
            const icons = { success: 'fa-check-circle', error: 'fa-times-circle', info: 'fa-info-circle' };
            const colors = { success: '#4ade80', error: '#f87171', info: 'var(--accent-light)' };
            toast.innerHTML = `
                <i class="fas ${icons[type]}" style="color:${colors[type]};font-size:1.1rem;"></i>
                <span style="color:var(--white);font-size:0.92rem;">${message}</span>
                <button onclick="this.parentElement.remove()"
                        style="background:none;border:none;color:var(--gray-text);margin-left:auto;cursor:pointer;font-size:1rem;">
                    <i class="fas fa-times"></i>
                </button>`;
            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 10);
            setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 400); }, 4000);
        }

        // ---- Active nav link highlight ----
        document.querySelectorAll('.navbar-textwave .nav-link').forEach(link => {
            if (link.href === window.location.href) link.classList.add('active');
        });
    </script>

    <!-- Add back-to-top style -->
    <style>
        .back-to-top {
            position: fixed;
            bottom: 30px; right: 30px;
            width: 44px; height: 44px;
            background: var(--gradient-primary);
            color: var(--white);
            border: none;
            border-radius: 50%;
            cursor: pointer;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
            z-index: 999;
            box-shadow: var(--shadow-md);
            display: flex; align-items: center; justify-content: center;
        }
        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }
        .back-to-top:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }
    </style>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>