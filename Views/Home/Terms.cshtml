@section Styles {
    <style>
        .page-hero {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--dark-3) 50%, var(--dark-2) 100%);
            padding: 140px 0 80px;
            position: relative;
            overflow: hidden;
        }

            .page-hero::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -20%;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(180,95,129,0.12) 0%, transparent 70%);
                border-radius: 50%;
            }

        .page-hero-title {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 800;
            color: var(--white);
            margin-bottom: 16px;
        }

        .page-hero-subtitle {
            color: var(--gray-text);
            font-size: 1.05rem;
            max-width: 600px;
            margin: 0 auto 20px;
            line-height: 1.8;
        }

        .terms-meta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

            .terms-meta span {
                color: var(--gray-text);
                font-size: 0.85rem;
                display: flex;
                align-items: center;
                gap: 7px;
            }

            .terms-meta i {
                color: var(--accent-light);
            }

        /* SIDEBAR */
        .terms-sidebar {
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 24px;
            position: sticky;
            top: 100px;
        }

        .ts-header {
            color: var(--white);
            font-weight: 700;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border-color);
        }

            .ts-header i {
                color: var(--accent-light);
            }

        .ts-nav {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .ts-link {
            color: var(--gray-text);
            font-size: 0.82rem;
            padding: 8px 12px;
            border-radius: var(--radius-sm);
            text-decoration: none;
            transition: var(--transition);
            border-left: 2px solid transparent;
            line-height: 1.4;
        }

            .ts-link:hover {
                color: var(--accent-light);
                background: rgba(180,95,129,0.06);
                border-left-color: rgba(180,95,129,0.3);
            }

            .ts-link.active {
                color: var(--accent-light);
                background: rgba(180,95,129,0.1);
                border-left-color: var(--accent);
                font-weight: 600;
            }

        .ts-download {
            margin-top: 20px;
            padding-top: 16px;
            border-top: 1px solid var(--border-color);
        }

        .ts-dl-btn {
            width: 100%;
            background: rgba(180,95,129,0.08);
            border: 1px solid var(--border-color);
            color: var(--gray-text);
            padding: 10px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: var(--transition);
            font-family: 'Inter', sans-serif;
        }

            .ts-dl-btn:hover {
                border-color: var(--accent);
                color: var(--accent-light);
                background: rgba(180,95,129,0.12);
            }

        /* SECTIONS */
        .terms-content {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .terms-intro-banner {
            background: linear-gradient(135deg, rgba(112,25,61,0.2), rgba(42,21,32,0.6));
            border: 1px solid rgba(180,95,129,0.3);
            border-radius: var(--radius-md);
            padding: 20px 24px;
            display: flex;
            gap: 16px;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .terms-intro-icon {
            color: var(--accent-light);
            font-size: 1.4rem;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .terms-intro-banner div {
            color: var(--gray-text);
            font-size: 0.92rem;
            line-height: 1.7;
        }

        .terms-intro-banner strong {
            color: var(--white);
        }

        .terms-section {
            padding: 40px 0;
            border-bottom: 1px solid rgba(180,95,129,0.08);
        }

            .terms-section:last-of-type {
                border-bottom: none;
            }

        .ts-section-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 24px;
        }

        .ts-num {
            font-family: 'Poppins', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            flex-shrink: 0;
            opacity: 0.6;
        }

        .ts-section-header h2 {
            color: var(--white);
            font-size: 1.4rem;
            font-weight: 800;
            margin: 0;
        }

        .terms-section p {
            color: var(--gray-text);
            line-height: 1.85;
            font-size: 0.94rem;
            margin-bottom: 16px;
        }

            .terms-section p:last-child {
                margin-bottom: 0;
            }

        /* HIGHLIGHT BOXES */
        .terms-highlight {
            display: flex;
            gap: 14px;
            align-items: flex-start;
            background: rgba(14,165,233,0.06);
            border: 1px solid rgba(14,165,233,0.2);
            border-radius: var(--radius-md);
            padding: 16px 20px;
            margin: 20px 0;
        }

            .terms-highlight i {
                color: #38bdf8;
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: 2px;
            }

            .terms-highlight p {
                color: #a0d4e8;
                font-size: 0.9rem;
                line-height: 1.7;
                margin: 0 !important;
            }

        .terms-warning {
            background: rgba(245,158,11,0.06);
            border-color: rgba(245,158,11,0.2);
        }

            .terms-warning i {
                color: #fbbf24;
            }

            .terms-warning p {
                color: #e8d5a0;
            }

        .terms-success {
            background: rgba(74,222,128,0.06);
            border-color: rgba(74,222,128,0.2);
        }

            .terms-success i {
                color: #4ade80;
            }

            .terms-success p {
                color: #a8d5b5;
            }

        /* LISTS */
        .terms-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin: 16px 0;
        }

        .tl-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

            .tl-item i {
                color: #4ade80;
                font-size: 0.85rem;
                flex-shrink: 0;
                margin-top: 3px;
            }

            .tl-item span {
                color: var(--gray-text);
                font-size: 0.92rem;
                line-height: 1.6;
            }

        .terms-list-prohibited .tl-item i {
            color: #f87171;
        }

        /* GRID CARDS */
        .terms-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin: 20px 0;
        }

        .tg-card {
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 24px 20px;
            transition: var(--transition);
        }

            .tg-card:hover {
                border-color: rgba(180,95,129,0.4);
                transform: translateY(-4px);
            }

        .tg-icon {
            width: 44px;
            height: 44px;
            background: rgba(180,95,129,0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-light);
            font-size: 1.1rem;
            margin-bottom: 14px;
        }

        .tg-card h5 {
            color: var(--white);
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 8px;
        }

        .tg-card p {
            color: var(--gray-text);
            font-size: 0.84rem;
            line-height: 1.65;
            margin: 0;
        }

        /* CONTACT GRID */
        .terms-contact-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin: 20px 0;
        }

        .tc-card {
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 24px 20px;
            text-align: center;
            transition: var(--transition);
        }

            .tc-card:hover {
                border-color: rgba(180,95,129,0.4);
                transform: translateY(-4px);
            }

        .tc-icon {
            width: 48px;
            height: 48px;
            background: var(--gradient-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-size: 1.1rem;
            margin: 0 auto 14px;
        }

        .tc-card h6 {
            color: var(--white);
            font-weight: 700;
            font-size: 0.88rem;
            margin-bottom: 6px;
        }

        .tc-card p {
            color: var(--gray-text);
            font-size: 0.84rem;
            margin: 0;
        }

        /* FOOTER NOTE */
        .terms-footer-note {
            background: linear-gradient(135deg, rgba(112,25,61,0.15), rgba(42,21,32,0.5));
            border: 1px solid rgba(180,95,129,0.2);
            border-radius: var(--radius-md);
            padding: 20px 24px;
            display: flex;
            gap: 14px;
            align-items: flex-start;
            margin-top: 40px;
        }

            .terms-footer-note i {
                color: #4ade80;
                font-size: 1.1rem;
                flex-shrink: 0;
                margin-top: 2px;
            }

            .terms-footer-note p {
                color: var(--gray-text);
                font-size: 0.88rem;
                line-height: 1.7;
                margin: 0;
            }

        @@media (max-width: 992px) {
            .terms-sidebar {
                position: relative;
                top: 0;
                margin-bottom: 32px;
            }
        }

        @@media (max-width: 768px) {
            .terms-grid {
                grid-template-columns: 1fr;
            }

            .terms-contact-grid {
                grid-template-columns: 1fr;
            }

            .ts-num {
                font-size: 1.8rem;
            }
        }
    </style>
}

@section Scripts {
    <script>
        function setActive(el) {
            document.querySelectorAll('.ts-link').forEach(function(l) { l.classList.remove('active'); });
            el.classList.add('active');
        }

        window.addEventListener('scroll', function() {
            var sections = document.querySelectorAll('.terms-section');
            var links = document.querySelectorAll('.ts-link');
            var scrollPos = window.scrollY + 140;
            sections.forEach(function(sec, i) {
                if (sec.offsetTop <= scrollPos && (sec.offsetTop + sec.offsetHeight) > scrollPos) {
                    links.forEach(function(l) { l.classList.remove('active'); });
                    if (links[i]) links[i].classList.add('active');
                }
            });
        });
    </script>
}
