<!-- ARTICLE READER MODAL -->
<div class="tw-modal-backdrop" id="twModalBackdrop" onclick="twCloseArticle()"></div>
<div class="tw-article-modal" id="twArticleModal">
    <div class="tw-progress-bar" id="twProgressBar"></div>
    <div class="tw-modal-header">
        <div class="tw-modal-header-left">
            <span class="tw-modal-cat" id="twModalCat"></span>
            <span class="tw-modal-time" id="twModalTime"></span>
        </div>
        <button class="tw-modal-close" onclick="twCloseArticle()" title="Close article">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <div class="tw-modal-scroll" id="twModalScroll" onscroll="twUpdateProgress()">
        <div class="tw-modal-strip" id="twModalStrip"></div>
        <div class="tw-modal-body">
            <h1 class="tw-modal-title" id="twModalTitle"></h1>
            <div class="tw-modal-meta">
                <div class="tw-author tw-author-lg">
                    <div class="tw-av" id="twModalAv"></div>
                    <div>
                        <strong id="twModalAuthor"></strong>
                        <span id="twModalDate"></span>
                    </div>
                </div>
                <div class="tw-modal-stats">
                    <span><i class="fas fa-eye"></i> <span id="twModalViews"></span></span>
                    <span><i class="fas fa-heart"></i> <span id="twModalLikes"></span></span>
                </div>
            </div>
            <div class="tw-modal-divider"></div>
            <div class="tw-article-content" id="twArticleContent"></div>
            <div class="tw-modal-cta" id="twModalCta" style="display:none;">
                <div class="tw-modal-cta-inner">
                    <i class="fas fa-unlock tw-cta-icon"></i>
                    <h4>Enjoyed This Article?</h4>
                    <p>Create a free TextWave account to save articles, join the community and get weekly SMS insights delivered to your inbox.</p>
                    <div class="tw-cta-btns">
                        <a href="/Identity/Account/Register" class="btn-primary-tw justify-content-center"><i class="fas fa-user-plus"></i> Create Free Account</a>
                        <a href="/Identity/Account/Login" class="btn-outline-tw justify-content-center"><i class="fas fa-sign-in-alt"></i> Sign In</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tw-blog-hero {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--dark-3) 50%, var(--dark-2) 100%);
            padding: 140px 0 100px;
            position: relative;
            overflow: hidden;
        }

        .tw-grid-overlay {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(180,95,129,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(180,95,129,0.05) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }

        .tw-blob {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .tw-blob-1 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(112,25,61,0.2) 0%, transparent 70%);
            top: -200px;
            right: -150px;
            animation: pulse-glow 7s ease-in-out infinite;
        }

        .tw-blob-2 {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(180,95,129,0.12) 0%, transparent 70%);
            bottom: -100px;
            left: -80px;
            animation: pulse-glow 9s ease-in-out infinite 3s;
        }

        .tw-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(180,95,129,0.1);
