@{
    ViewData["Title"] = "Blog";
    ViewData["ActivePage"] = "Blog";
}

<!-- PAGE HERO -->
<section class="tw-blog-hero">
    <div class="tw-grid-overlay"></div>
    <div class="tw-blob tw-blob-1"></div>
    <div class="tw-blob tw-blob-2"></div>
    <div class="container position-relative">
        <div class="row justify-content-center text-center">
            <div class="col-lg-9 animate-fadeInUp">
                <div class="tw-eyebrow">
                    <span class="tw-eyebrow-dot"></span>
                    TextWave Journal
                    <span class="tw-eyebrow-dot"></span>
                </div>
                <h1 class="tw-blog-h1">
                    Ideas That Move<br />
                    <span class="gradient-text">Business Forward</span>
                </h1>
                <p class="tw-blog-sub">
                    Deep dives, case studies and tactical guides on SMS marketing,
                    automation and growth — written by practitioners, not theorists.
                </p>
                <div class="breadcrumb-tw justify-content-center mt-3">
                    <a href="/">Home</a>
                    <i class="fas fa-chevron-right" style="font-size:.7rem"></i>
                    <span>Blog</span>
                </div>
                <div class="tw-hero-stats">
                    <div class="tw-hs"><strong>50+</strong><span>Articles</span></div>
                    <div class="tw-hs-sep"></div>
                    <div class="tw-hs"><strong>12K+</strong><span>Readers</span></div>
                    <div class="tw-hs-sep"></div>
                    <div class="tw-hs"><strong>Weekly</strong><span>New Posts</span></div>
                    <div class="tw-hs-sep"></div>
                    <div class="tw-hs"><strong>6</strong><span>Categories</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORY FILTERS ONLY - NO SEARCH BAR -->
<section class="tw-filter-bar">
    <div class="container">
        <div class="tw-filters reveal">
            <button class="tw-filter active" onclick="twSetFilter(this,'all')"><i class="fas fa-th-large"></i> All Posts</button>
            <button class="tw-filter" onclick="twSetFilter(this,'sms')"><i class="fas fa-comment-dots"></i> SMS Marketing</button>
            <button class="tw-filter" onclick="twSetFilter(this,'tutorial')"><i class="fas fa-graduation-cap"></i> Tutorials</button>
            <button class="tw-filter" onclick="twSetFilter(this,'industry')"><i class="fas fa-chart-line"></i> Industry News</button>
            <button class="tw-filter" onclick="twSetFilter(this,'product')"><i class="fas fa-star"></i> Product Updates</button>
            <button class="tw-filter" onclick="twSetFilter(this,'case')"><i class="fas fa-trophy"></i> Case Studies</button>
        </div>
    </div>
</section>

<!-- FEATURED POST -->
<section class="section-padding-sm" id="twFeaturedSection">
    <div class="container">
        <div class="tw-featured-label reveal">
            <div class="section-tag">Featured Article</div>
            <div class="tw-label-line"></div>
        </div>
        <div class="tw-featured reveal" data-cat="sms">
            <div class="row align-items-center g-0">
                <div class="col-lg-5">
                    <div class="tw-fp-visual">
                        <div class="tw-fp-blob tw-fp-b1"></div>
                        <div class="tw-fp-blob tw-fp-b2"></div>
                        <div class="tw-fp-phone">
                            <div class="tw-fp-notch"></div>
                            <div class="tw-fp-screen">
                                <div class="tw-fp-msg tw-fp-m1"><i class="fas fa-rocket"></i><div><strong>Flash Sale!</strong><span>50% off today only</span></div></div>
                                <div class="tw-fp-msg tw-fp-m2"><span class="tw-fp-bubble">Use code: <strong>WAVE50</strong></span></div>
                                <div class="tw-fp-msg tw-fp-m3"><span class="tw-fp-bubble tw-fp-reply">Claimed! 🎉</span></div>
                                <div class="tw-fp-msg tw-fp-m4"><span class="tw-fp-typing"><span></span><span></span><span></span></span></div>
                            </div>
                        </div>
                        <div class="tw-fp-stat tw-fp-s1"><strong>98%</strong><span>Open Rate</span></div>
                        <div class="tw-fp-stat tw-fp-s2"><strong>45%</strong><span>CTR</span></div>
                        <div class="tw-fp-stat tw-fp-s3"><strong>3min</strong><span>Avg Read</span></div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="tw-fp-content">
                        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
                            <span class="tw-badge tw-b-sms"><i class="fas fa-comment-dots me-1"></i>SMS Marketing</span>
                            <span class="tw-badge tw-b-featured"><i class="fas fa-fire me-1"></i>Featured</span>
                        </div>
                        <h2 class="tw-fp-title">The Ultimate Guide to SMS Marketing in 2025</h2>
                        <p class="tw-fp-desc">Everything you need to build a high-converting SMS marketing strategy — from list building and segmentation to personalization, automation and compliance. Packed with real data and actionable tactics.</p>
                        <div class="tw-fp-meta">
                            <div class="tw-author">
                                <div class="tw-av tw-av1">JM</div>
                                <div><strong>James Morgan</strong><span>Mar 10, 2025 · 12 min read</span></div>
                            </div>
                            <div class="tw-fp-nums"><span><i class="fas fa-eye"></i> 24.3K</span><span><i class="fas fa-heart"></i> 891</span></div>
                        </div>
                        <button class="tw-read-btn" onclick="twOpenArticle('featured')">
                            <span class="tw-read-label"><i class="fas fa-book-open"></i> Read Full Article</span>
                            <span class="tw-read-arr"><i class="fas fa-arrow-right"></i></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

