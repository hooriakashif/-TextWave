
@{
    ViewData["Title"] = "Pricing";
    ViewData["ActivePage"] = "Pricing";

}
@Html.AntiForgeryToken()
<!-- ========== PAGE HERO ========== -->
<section class="page-hero">
    <div class="container position-relative">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8 animate-fadeInUp">
                <div class="section-tag mb-3">Simple Pricing</div>
                <h1 class="page-hero-title">
                    Transparent Pricing,
                    <span class="gradient-text"> Zero Surprises</span>
                </h1>
                <p class="page-hero-subtitle">
                    Start free, scale as you grow. No hidden fees, no long contracts.
                    Pay only for what you send.
                </p>
                <div class="breadcrumb-tw justify-content-center mt-3">
                    <a href="/">Home</a>
                    <i class="fas fa-chevron-right" style="font-size:0.7rem;"></i>
                    <span>Pricing</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== BILLING TOGGLE ========== -->
<section class="section-padding-sm">
    <div class="container">
        <div class="billing-toggle-wrapper reveal">
            <span class="billing-label" id="lblMonthly">Monthly</span>
            <div class="billing-toggle" id="billingToggle">
                <div class="billing-toggle-thumb"></div>
            </div>
            <span class="billing-label" id="lblAnnual">
                Annual
                <span class="save-badge">Save 20%</span>
            </span>
        </div>
        <div class="row g-4 mt-2 justify-content-center">
            <!-- Starter -->
            <div class="col-lg-4 col-md-6 reveal delay-1">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <div class="pricing-icon"><i class="fas fa-seedling"></i></div>
                        <h4 class="pricing-plan">Starter</h4>
                        <p class="pricing-desc">Perfect for small businesses getting started</p>
                        <div class="pricing-price">
                            <span class="price-currency">$</span>
                            <span class="price-amount" data-monthly="29" data-annual="23">29</span>
                            <span class="price-period">/mo</span>
                        </div>
                        <p class="price-annual-note" id="annualNote1"></p>
                    </div>
                    <div class="pricing-features">
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>5,000 SMS / month</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>1 Sender ID</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Basic Analytics</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Email Support</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>API Access</span></div>
                        <div class="pf-item pf-no"><i class="fas fa-times"></i><span>Two-Way SMS</span></div>
                        <div class="pf-item pf-no"><i class="fas fa-times"></i><span>Dedicated Account Manager</span></div>
                        <div class="pf-item pf-no"><i class="fas fa-times"></i><span>Custom Integrations</span></div>
                    </div>
                    <button type="button" class="btn-pricing" onclick="handlePlanSelect('Starter')">
                        <i class="fas fa-rocket"></i> Get Started
                    </button>
                </div>
            </div>
            <!-- Professional -->
            <div class="col-lg-4 col-md-6 reveal delay-2">
                <div class="pricing-card pricing-featured">
                    <div class="pricing-badge">Most Popular</div>
                    <div class="pricing-header">
                        <div class="pricing-icon"><i class="fas fa-bolt"></i></div>
                        <h4 class="pricing-plan">Professional</h4>
                        <p class="pricing-desc">For growing businesses that need more power</p>
                        <div class="pricing-price">
                            <span class="price-currency">$</span>
                            <span class="price-amount" data-monthly="79" data-annual="63">79</span>
                            <span class="price-period">/mo</span>
                        </div>
                        <p class="price-annual-note" id="annualNote2"></p>
                    </div>
                    <div class="pricing-features">
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>25,000 SMS / month</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>5 Sender IDs</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Advanced Analytics</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Priority Support 24/7</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>API Access</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Two-Way SMS</span></div>
                        <div class="pf-item pf-no"><i class="fas fa-times"></i><span>Dedicated Account Manager</span></div>
                        <div class="pf-item pf-no"><i class="fas fa-times"></i><span>Custom Integrations</span></div>
                    </div>
                    <button type="button" class="btn-pricing btn-pricing-featured" onclick="handlePlanSelect('Professional')">
                        <i class="fas fa-bolt"></i> Get Started
                    </button>
                </div>
            </div>
            <!-- Enterprise -->
            <div class="col-lg-4 col-md-6 reveal delay-3">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <div class="pricing-icon"><i class="fas fa-building"></i></div>
                        <h4 class="pricing-plan">Enterprise</h4>
                        <p class="pricing-desc">For large scale operations with custom needs</p>
                        <div class="pricing-price">
                            <span class="price-currency">$</span>
                            <span class="price-amount" data-monthly="199" data-annual="159">199</span>
                            <span class="price-period">/mo</span>
                        </div>
                        <p class="price-annual-note" id="annualNote3"></p>
                    </div>
                    <div class="pricing-features">
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Unlimited SMS</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Unlimited Sender IDs</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Custom Analytics</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Dedicated Support</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>API Access</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Two-Way SMS</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Dedicated Account Manager</span></div>
                        <div class="pf-item pf-yes"><i class="fas fa-check"></i><span>Custom Integrations</span></div>
                    </div>
                    <button type="button" class="btn-pricing" onclick="handlePlanSelect('Enterprise')">
                        <i class="fas fa-crown"></i> Get Started
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- LUXURY CREATE YOUR OWN BUNDLE CTA -->
    <div class="row mt-5">
        <div class="col-12 text-center reveal">
            <div class="custom-bundle-cta">
                <div class="cta-content">
                    <i class="fas fa-magic cta-icon"></i>
                    <div>
                        <h3>Don't see a plan that fits?</h3>
                        <p>Build a custom package tailored specifically to your business needs.</p>
                    </div>
                </div>
                <button type="button" class="btn-create-custom" onclick="openCustomCreator()">
                    <i class="fas fa-plus-circle"></i> Want to create your own bundle?
                </button>
            </div>
        </div>
    </div>
</section>

<!-- ========== SMS CALCULATOR ========== -->
<section class="section-padding calc-section">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">SMS Calculator</div>
            <h2 class="section-title">Calculate Your <span>Exact Cost</span></h2>
            <p class="section-subtitle">Slide to see exactly what you'll pay. No surprises ever.</p>
        </div>
        <div class="calculator-card reveal">
            <div class="row align-items-center g-5">
                <div class="col-lg-7">
                    <div class="calc-field">
                        <div class="calc-label-row">
                            <label class="form-label-tw">Number of SMS per month</label>
                            <span class="calc-value-display" id="smsCountDisplay">10,000</span>
                        </div>
                        <input type="range" class="calc-slider" id="smsSlider" min="1000" max="500000" step="1000" value="10000" />
                        <div class="calc-range-labels"><span>1K</span><span>500K</span></div>
                    </div>
                    <div class="calc-field mt-4">
                        <div class="calc-label-row">
                            <label class="form-label-tw">Select Country</label>
                            <span class="calc-value-display" id="rateDisplay">$0.025/SMS</span>
                        </div>
                        <div class="custom-select-wrapper">
                            <div class="custom-select-trigger" id="selectTrigger" onclick="toggleDropdown()">
                                <span class="cs-flag">&#127482;&#127480;</span>
                                <span class="cs-name">United States</span>
                                <span class="cs-rate">$0.025/SMS</span>
                                <i class="fas fa-chevron-down cs-arrow"></i>
                            </div>
                            <div class="custom-select-dropdown" id="selectDropdown">
                                <div class="cs-search-wrapper">
                                    <i class="fas fa-search cs-search-icon"></i>
                                    <input type="text" class="cs-search" id="csSearch" placeholder="Search country..." oninput="filterCountries(this.value)" />
                                </div>
                                <div class="cs-options" id="csOptions"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="calc-result">
                        <div class="calc-result-orb"></div>
                        <p class="calc-result-label">Estimated Monthly Cost</p>
                        <div class="calc-result-amount" id="calcResult">$250.00</div>
                        <div class="calc-result-breakdown">
                            <div class="crb-item"><span>SMS Count</span><strong id="crb-count">10,000</strong></div>
                            <div class="crb-item"><span>Rate per SMS</span><strong id="crb-rate">$0.025</strong></div>
                            <div class="crb-item"><span>Volume Discount</span><strong id="crb-discount" style="color:#4ade80;">-0%</strong></div>
                        </div>
                        <button type="button" class="btn-primary-tw w-100 mt-4" onclick="handlePlanSelect('Custom')">
                            <i class="fas fa-paper-plane"></i> Get This Plan
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== PAYMENT METHODS ========== -->
<section class="section-padding">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">Payment Methods</div>
            <h2 class="section-title">We Accept <span>All Major</span> Payments</h2>
            <p class="section-subtitle">Secure, fast and flexible payment options for every business.</p>
        </div>
        <div class="payment-grid reveal">
            <div class="payment-card" onclick="handlePayment('Visa')"><i class="fab fa-cc-visa payment-icon" style="color:#1a1f71;"></i><span>Visa</span></div>
            <div class="payment-card" onclick="handlePayment('Mastercard')"><i class="fab fa-cc-mastercard payment-icon" style="color:#eb001b;"></i><span>Mastercard</span></div>
            <div class="payment-card" onclick="handlePayment('PayPal')"><i class="fab fa-cc-paypal payment-icon" style="color:#003087;"></i><span>PayPal</span></div>
            <div class="payment-card" onclick="handlePayment('Stripe')"><i class="fab fa-cc-stripe payment-icon" style="color:#6772e5;"></i><span>Stripe</span></div>
            <div class="payment-card" onclick="handlePayment('Apple Pay')"><i class="fab fa-apple payment-icon" style="color:#a2aaad;"></i><span>Apple Pay</span></div>
            <div class="payment-card" onclick="handlePayment('Google Pay')"><i class="fab fa-google-pay payment-icon" style="color:#4285f4;"></i><span>Google Pay</span></div>
            <div class="payment-card" onclick="handlePayment('American Express')"><i class="fab fa-cc-amex payment-icon" style="color:#2e77bc;"></i><span>Amex</span></div>
            <div class="payment-card" onclick="handlePayment('Discover')"><i class="fab fa-cc-discover payment-icon" style="color:#f76f20;"></i><span>Discover</span></div>
            <div class="payment-card" onclick="handlePayment('JCB')"><i class="fab fa-cc-jcb payment-icon" style="color:#003087;"></i><span>JCB</span></div>
            <div class="payment-card" onclick="handlePayment('Diners Club')"><i class="fab fa-cc-diners-club payment-icon" style="color:#004b87;"></i><span>Diners Club</span></div>
            <div class="payment-card" onclick="handlePayment('Bitcoin')"><i class="fab fa-bitcoin payment-icon" style="color:#f7931a;"></i><span>Bitcoin</span></div>
            <div class="payment-card" onclick="handlePayment('Bank Transfer')"><i class="fas fa-university payment-icon" style="color:var(--accent-light);"></i><span>Bank Transfer</span></div>
        </div>
        <p class="text-center mt-4" style="color:var(--gray-text);font-size:0.88rem;">
            <i class="fas fa-lock me-2" style="color:#4ade80;"></i>All transactions are secured with 256-bit SSL encryption
        </p>
    </div>
</section>

<!-- ========== FAQ ========== -->
<section class="section-padding faq-section">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">FAQ</div>
            <h2 class="section-title">Pricing <span>Questions Answered</span></h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8 reveal">
                <div class="faq-list">
                    <div class="faq-item">
                        <button type="button" class="faq-question" onclick="toggleFaq(this)"><span>Can I change my plan anytime?</span><i class="fas fa-plus faq-icon"></i></button>
                        <div class="faq-answer"><p>Yes! You can upgrade or downgrade your plan at any time. Changes take effect immediately and we'll prorate any billing differences automatically.</p></div>
                    </div>
                    <div class="faq-item">
                        <button type="button" class="faq-question" onclick="toggleFaq(this)"><span>Is there a free trial?</span><i class="fas fa-plus faq-icon"></i></button>
                        <div class="faq-answer"><p>Absolutely! Sign up for free and get 100 SMS credits instantly — no credit card required. Test the full platform before committing to a plan.</p></div>
                    </div>
                    <div class="faq-item">
                        <button type="button" class="faq-question" onclick="toggleFaq(this)"><span>What happens if I exceed my SMS limit?</span><i class="fas fa-plus faq-icon"></i></button>
                        <div class="faq-answer"><p>We'll notify you when you reach 80% of your limit. If you exceed it, additional SMS are charged at our standard per-SMS rate for your plan — no service interruptions.</p></div>
                    </div>
                    <div class="faq-item">
                        <button type="button" class="faq-question" onclick="toggleFaq(this)"><span>Are there any setup fees or contracts?</span><i class="fas fa-plus faq-icon"></i></button>
                        <div class="faq-answer"><p>Zero setup fees and zero long-term contracts. All plans are month-to-month. Cancel anytime with no penalties whatsoever.</p></div>
                    </div>
                    <div class="faq-item">
                        <button type="button" class="faq-question" onclick="toggleFaq(this)"><span>Do you offer refunds?</span><i class="fas fa-plus faq-icon"></i></button>
                        <div class="faq-answer"><p>We offer a 30-day money-back guarantee on all paid plans. If you're not satisfied, contact our support team and we'll process a full refund — no questions asked.</p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== AUTH MODAL ========== -->
<div class="auth-modal-overlay" id="authModal">
    <div class="auth-modal">
        <button class="auth-modal-close" onclick="closeAuthModal()"><i class="fas fa-times"></i></button>
        <div class="auth-modal-icon"><i class="fas fa-lock"></i></div>
        <h3 class="auth-modal-title">Login Required</h3>
        <p class="auth-modal-desc">You need to be logged in to select a plan or make a payment. Join thousands of businesses already using TextWave!</p>
        <div class="auth-modal-plan" id="selectedPlanDisplay"></div>
        <div class="auth-modal-actions">
            <a href="/Identity/Account/Login" class="btn-primary-tw w-100 justify-content-center mb-3"><i class="fas fa-sign-in-alt"></i> Sign In to Continue</a>
            <a href="/Identity/Account/Register" class="btn-outline-tw w-100 justify-content-center"><i class="fas fa-user-plus"></i> Create Free Account</a>
        </div>
        <p class="auth-modal-footer"><i class="fas fa-shield-alt me-1" style="color:#4ade80;"></i>Free account includes 100 SMS credits — no credit card needed</p>
    </div>
</div>

<!-- ========== PAYMENT CHECKOUT MODAL ========== -->
<div class="pay-overlay" id="paymentModal">
    <div class="pay-modal">
        <button type="button" class="pay-close" onclick="closePayModal()"><i class="fas fa-times"></i></button>
        <!-- Step 1 -->
        <div id="payStep1">
            <div class="pay-header">
                <div class="pay-logo"><i class="fas fa-wave-square"></i><span>TextWave</span></div>
                <div class="pay-secure"><i class="fas fa-lock"></i> Secure Checkout</div>
            </div>
            <div class="pay-plan-box">
                <div class="pay-plan-left">
                    <div class="pay-plan-icon"><i class="fas fa-bolt"></i></div>
                    <div>
                        <strong id="pay-plan-name">Professional Plan</strong>
                        <span>Billed today — cancel anytime</span>
                    </div>
                </div>
                <div class="pay-plan-price" id="pay-plan-amount">$79/mo</div>
            </div>
            <div class="pay-method-tabs">
                <button type="button" class="pay-tab active" onclick="switchTab(this,'card')"><i class="fas fa-credit-card"></i> Card</button>
                <button type="button" class="pay-tab" onclick="switchTab(this,'paypal')"><i class="fab fa-paypal"></i> PayPal</button>
                <button type="button" class="pay-tab" onclick="switchTab(this,'crypto')"><i class="fab fa-bitcoin"></i> Crypto</button>
            </div>
            <!-- Card Tab -->
            <div id="tab-card" class="pay-tab-content">
                <div class="pay-field">
                    <label>Cardholder Name</label>
                    <div class="pay-input-wrap"><i class="fas fa-user"></i><input type="text" id="cardName" placeholder="John Smith" /></div>
                </div>
                <div class="pay-field">
                    <label>Card Number</label>
                    <div class="pay-input-wrap">
                        <i class="fas fa-credit-card"></i>
                        <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19" oninput="formatCard(this)" />
                        <div class="card-brand" id="cardBrand"></div>
                    </div>
                </div>
                <div class="pay-row">
                    <div class="pay-field">
                        <label>Expiry Date</label>
                        <div class="pay-input-wrap"><i class="fas fa-calendar"></i><input type="text" id="cardExpiry" placeholder="MM/YY" maxlength="5" oninput="formatExpiry(this)" /></div>
                    </div>
                    <div class="pay-field">
                        <label>CVV</label>
                        <div class="pay-input-wrap"><i class="fas fa-lock"></i><input type="text" id="cardCvv" placeholder="123" maxlength="4" /></div>
                    </div>
                </div>
                <div class="pay-save-card">
                    <label class="pay-check">
                        <input type="checkbox" id="saveCard" />
                        <span class="pay-checkmark"></span>
                        <span>Save card for future payments</span>
                    </label>
                </div>
            </div>
            <!-- PayPal Tab -->
            <div id="tab-paypal" class="pay-tab-content" style="display:none;">
                <div class="pay-paypal-info">
                    <div class="pay-pp-icon"><i class="fab fa-paypal"></i></div>
                    <h4>Pay with PayPal</h4>
                    <p>You will be redirected to PayPal to complete your payment securely.</p>
                    <div class="pay-pp-email"><i class="fas fa-envelope"></i><input type="email" id="ppEmail" placeholder="your@paypal.com" /></div>
                </div>
            </div>
            <!-- Crypto Tab -->
            <div id="tab-crypto" class="pay-tab-content" style="display:none;">
                <div class="pay-paypal-info">
                    <div class="pay-pp-icon" style="background:rgba(247,147,26,0.15);color:#f7931a;"><i class="fab fa-bitcoin"></i></div>
                    <h4>Pay with Crypto</h4>
                    <p>We accept Bitcoin, Ethereum and USDT via Coinbase Commerce.</p>
                    <div class="pay-crypto-addr"><span>BTC Address:</span><code>bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh</code></div>
                </div>
            </div>
            <div class="pay-error" id="payError" style="display:none;"></div>
            <button type="button" class="pay-submit-btn" id="paySubmitBtn" onclick="submitPayment()">
                <i class="fas fa-lock"></i><span id="payBtnText">Complete Payment</span>
            </button>
            <div class="pay-footer-trust">
                <span><i class="fas fa-shield-alt"></i> 256-bit SSL</span>
                <span><i class="fas fa-undo"></i> 30-day refund</span>
                <span><i class="fas fa-award"></i> PCI Compliant</span>
            </div>
        </div>
        <!-- Step 2 Success -->
        <div id="payStep2" style="display:none;">
            <div class="pay-success">
                <div class="pay-success-circle"><i class="fas fa-check"></i></div>
                <h2>Payment Successful!</h2>
                <p>Welcome to TextWave <strong id="successPlan"></strong>!</p>
                <div class="pay-order-box">
                    <div class="pay-order-row"><span>Order Number</span><strong id="successOrderNum"></strong></div>
                    <div class="pay-order-row"><span>Plan</span><strong id="successPlanName"></strong></div>
                    <div class="pay-order-row"><span>Amount Charged</span><strong id="successAmount"></strong></div>
                    <div class="pay-order-row"><span>Email</span><strong id="successEmail"></strong></div>
                    <div class="pay-order-row"><span>Status</span><strong style="color:#4ade80;"><i class="fas fa-check-circle me-1"></i>Paid</strong></div>
                </div>
                <p class="pay-success-note">A confirmation email has been sent to your inbox. Your plan is now active!</p>
                <button type="button" class="pay-submit-btn" onclick="closePayModal()"><i class="fas fa-rocket"></i> Start Using TextWave</button>
            </div>
        </div>
    </div>
</div>

<!-- LUXURY CUSTOM CREATOR MODAL -->
<div class="creator-overlay" id="creatorModal">
    <div class="creator-modal">
        <button type="button" class="creator-close" onclick="closeCustomCreator()"><i class="fas fa-times"></i></button>
        <div class="creator-header">
            <div class="creator-icon"><i class="fas fa-tools"></i></div>
            <h2>Design Your Bundle</h2>
            <p>Fill in your requirements and we'll calculate the price.</p>
        </div>

        <div class="creator-body">
            <div class="row g-3">
                <div class="col-md-12">
                    <label class="form-label-tw">Give your plan a name</label>
                    <input type="text" id="custName" class="form-input-tw" placeholder="e.g. My VIP Package">
                </div>
                <div class="col-md-6">
                    <label class="form-label-tw">Monthly SMS Count</label>
                    <input type="number" id="custSms" class="form-input-tw" value="10000" oninput="calculateCustomPrice()">
                </div>
                <div class="col-md-6">
                    <label class="form-label-tw">Sender IDs Required</label>
                    <input type="number" id="custSender" class="form-input-tw" value="1">
                </div>
                <div class="col-md-6">
                    <label class="form-label-tw">Target Country</label>
                    <select id="custCountry" class="form-input-tw" onchange="calculateCustomPrice()">
                        <option value="0.025" data-name="United States">🇺🇸 USA ($0.025)</option>
                        <option value="8.50" data-name="Pakistan">🇵🇰 Pakistan (Rs 8.50)</option>
                        <option value="0.030" data-name="UK">🇬🇧 UK (£0.030)</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label-tw">Support Type</label>
                    <select id="custSupport" class="form-input-tw">
                        <option value="Standard">Standard Email</option>
                        <option value="Priority">24/7 Priority</option>
                        <option value="Dedicated">Dedicated Manager</option>
                    </select>
                </div>
            </div>

            <div class="creator-price-box">
