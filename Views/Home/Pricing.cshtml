        .btn-create-custom {
            background: var(--gradient-primary);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 12px;
            font-weight: 700;
            transition: 0.3s;
            box-shadow: 0 10px 20px rgba(112,25,61,0.3);
        }

            .btn-create-custom:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(112,25,61,0.5);
            }

        /* Creator Modal */
        .creator-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(10px);
            z-index: 10002;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .creator-modal {
            background: #1a0d13;
            border: 1px solid rgba(180,95,129,0.3);
            border-radius: 24px;
            max-width: 600px;
            width: 100%;
            padding: 40px;
            position: relative;
            animation: modalIn 0.4s ease;
        }

        @@keyframes modalIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .creator-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .creator-icon {
            width: 60px;
            height: 60px;
            background: var(--gradient-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin: 0 auto 15px;
            font-size: 1.5rem;
        }

        .creator-header h2 {
            color: white;
            font-weight: 800;
            margin-bottom: 5px;
        }

        .creator-header p {
            color: var(--gray-text);
        }

        .form-input-tw {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-color);
            padding: 12px;
            border-radius: 10px;
            color: white;
            outline: none;
            margin-top: 5px;
        }

        .creator-price-box {
            margin-top: 25px;
            padding: 20px;
            background: rgba(112,25,61,0.2);
            border-radius: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .creator-price-box strong {
                font-size: 2rem;
                color: var(--accent-light);
            }

        .creator-close {
            position: absolute;
            top: 20px;
            right: 20px;
            background: none;
            border: none;
            color: var(--gray-text);
            cursor: pointer;
        }
    </style>
}

@section Scripts {
    <script>
        (function () {
            'use strict';

            var isLoggedIn = '@User.Identity.IsAuthenticated.ToString().ToLower()' === 'true';
            var isAnnual = false;
            var currentPlan = '';
            var currentAmount = 0;
            var activeTab = 'card';
            var selectedCountry = null;

            var countries = [
                { flag: '\uD83C\uDDFA\uD83C\uDDF8', name: 'United States',  rate: 0.025, symbol: '$'   },
                { flag: '\uD83C\uDDEC\uD83C\uDDE7', name: 'United Kingdom', rate: 0.030, symbol: '\u00a3'   },
                { flag: '\uD83C\uDDF5\uD83C\uDDF0', name: 'Pakistan',        rate: 8.50,  symbol: '\u20a8'   },
                { flag: '\uD83C\uDDEE\uD83C\uDDF3', name: 'India',           rate: 2.10,  symbol: '\u20b9'   },
                { flag: '\uD83C\uDDE6\uD83C\uDDFA', name: 'Australia',       rate: 0.038, symbol: 'A$'  },
                { flag: '\uD83C\uDDE8\uD83C\uDDE6', name: 'Canada',          rate: 0.034, symbol: 'C$'  },
                { flag: '\uD83C\uDDE9\uD83C\uDDEA', name: 'Germany',         rate: 0.075, symbol: '\u20ac'   },
                { flag: '\uD83C\uDDEB\uD83C\uDDF7', name: 'France',          rate: 0.065, symbol: '\u20ac'   },
                { flag: '\uD83C\uDDE6\uD83C\uDDEA', name: 'UAE',             rate: 0.100, symbol: 'AED' },
                { flag: '\uD83C\uDDF8\uD83C\uDDE6', name: 'Saudi Arabia',    rate: 0.090, symbol: 'SAR' },
                { flag: '\uD83C\uDDE7\uD83C\uDDE9', name: 'Bangladesh',      rate: 0.45,  symbol: 'BDT' },
                { flag: '\uD83C\uDDF3\uD83C\uDDEC', name: 'Nigeria',         rate: 4.20,  symbol: '\u20a6'   },
                { flag: '\uD83C\uDDE7\uD83C\uDDF7', name: 'Brazil',          rate: 0.125, symbol: 'R$'  },
                { flag: '\uD83C\uDDF2\uD83C\uDDFD', name: 'Mexico',          rate: 0.480, symbol: '$'   },
                { flag: '\uD83C\uDDFF\uD83C\uDDE6', name: 'South Africa',    rate: 0.450, symbol: 'R'   },
                { flag: '\uD83C\uDDF8\uD83C\uDDEC', name: 'Singapore',       rate: 0.033, symbol: 'S$'  },
                { flag: '\uD83C\uDDEF\uD83C\uDDF5', name: 'Japan',           rate: 2.80,  symbol: '\u00a5'   },
                { flag: '\uD83C\uDDE8\uD83C\uDDF3', name: 'China',           rate: 0.043, symbol: '\u00a5'   },
                { flag: '\uD83C\uDDF0\uD83C\uDDF7', name: 'South Korea',     rate: 28.00, symbol: '\u20a9'   },
                { flag: '\uD83C\uDDF9\uD83C\uDDF7', name: 'Turkey',          rate: 0.680, symbol: '\u20ba'   },
                { flag: '\uD83C\uDDEE\uD83C\uDDE9', name: 'Indonesia',       rate: 375.0, symbol: 'Rp'  },
                { flag: '\uD83C\uDDF5\uD83C\uDDED', name: 'Philippines',     rate: 1.40,  symbol: '\u20b1'   },
                { flag: '\uD83C\uDDF2\uD83C\uDDFE', name: 'Malaysia',        rate: 0.115, symbol: 'RM'  },
                { flag: '\uD83C\uDDEA\uD83C\uDDEC', name: 'Egypt',           rate: 0.780, symbol: 'E\u00a3'  },
                { flag: '\uD83C\uDDE6\uD83C\uDDF7', name: 'Argentina',       rate: 25.00, symbol: '$'   }
            ];

            selectedCountry = countries[0];

            function showToast(message, type) {
                var container = document.getElementById('toastContainer');
                if (!container) {
                    container = document.createElement('div');
                    container.id = 'toastContainer';
                    container.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99999;';
                    document.body.appendChild(container);
                }
                var colors = { success: '#4ade80', error: '#f87171', info: '#3b82f6' };
                var icons  = { success: 'fa-check-circle', error: 'fa-exclamation-circle', info: 'fa-info-circle' };
                var t = type || 'info';
                var toast = document.createElement('div');
                toast.style.cssText = 'background:' + (colors[t] || colors.info) + ';color:#fff;padding:14px 20px;border-radius:10px;margin-bottom:10px;box-shadow:0 4px 15px rgba(0,0,0,0.3);display:flex;align-items:center;gap:12px;min-width:280px;font-size:0.95rem;opacity:0;transform:translateX(100%);transition:all 0.4s ease;font-family:Inter,sans-serif;';
                toast.innerHTML = '<i class="fas ' + (icons[t] || icons.info) + '"></i><span>' + message + '</span>';
                container.appendChild(toast);
                setTimeout(function () { toast.style.opacity = '1'; toast.style.transform = 'translateX(0)'; }, 10);
                setTimeout(function () {
                    toast.style.opacity = '0'; toast.style.transform = 'translateX(100%)';
                    setTimeout(function () { toast.remove(); }, 400);
                }, 3500);
            }

            var toggle = document.getElementById('billingToggle');
            if (toggle) {
                toggle.addEventListener('click', function () {
                    isAnnual = !isAnnual;
                    toggle.classList.toggle('annual', isAnnual);
                    document.querySelectorAll('.price-amount').forEach(function (el) {
                        el.textContent = isAnnual ? el.getAttribute('data-annual') : el.getAttribute('data-monthly');
                    });
                    var annualAmounts = [23, 63, 159];
                    ['annualNote1', 'annualNote2', 'annualNote3'].forEach(function (id, i) {
                        var el = document.getElementById(id);
                        if (el) el.textContent = isAnnual ? 'Billed annually ($' + (annualAmounts[i] * 12) + '/yr)' : '';
                    });
                });
            }

            window.handlePlanSelect = function (planName) {
                currentPlan = planName;
                var prices = { Starter: 29, Professional: 79, Enterprise: 199, Custom: 0 };
                currentAmount = isAnnual ? Math.round((prices[planName] || 0) * 0.8) : (prices[planName] || 0);

                if (!isLoggedIn) {
                    document.getElementById('selectedPlanDisplay').textContent = 'Selected: ' + planName + ' Plan';
                    document.getElementById('authModal').classList.add('active');
                    document.body.style.overflow = 'hidden';
                    return;
                }

                var planNameEl = document.getElementById('pay-plan-name');
                var planAmountEl = document.getElementById('pay-plan-amount');

                if (planName === 'Custom' || planName === 'Custom Bundle') {
                    var calcAmount = planName === 'Custom' ? document.getElementById('calcResult').textContent : document.getElementById('custPriceDisplay').textContent;
                    planNameEl.textContent = 'Custom SMS Plan';
                    planAmountEl.textContent = calcAmount + (isAnnual ? ' (Annual)' : '');
                } else {
                    planNameEl.textContent = planName + ' Plan';
                    planAmountEl.textContent = '$' + currentAmount + (isAnnual ? ' (Annual)' : '/mo');
                }

                document.getElementById('paymentModal').classList.add('active');
                document.body.style.overflow = 'hidden';
            };

            window.handlePayment = function (method) {
                if (!isLoggedIn) {
                    document.getElementById('selectedPlanDisplay').textContent = 'Payment via: ' + method;
                    document.getElementById('authModal').classList.add('active');
                    document.body.style.overflow = 'hidden';
                    return;
                }
                var urls = {
                    'Visa': 'https://www.visa.com', 'Mastercard': 'https://www.mastercard.com',
                    'PayPal': 'https://www.paypal.com/checkoutnow', 'Stripe': 'https://buy.stripe.com',
                    'Apple Pay': 'https://www.apple.com/apple-pay', 'Google Pay': 'https://pay.google.com',
                    'American Express': 'https://www.americanexpress.com', 'Discover': 'https://www.discover.com',
                    'JCB': 'https://www.jcbcorporate.com', 'Diners Club': 'https://www.dinersclub.com',
                    'Bitcoin': 'https://commerce.coinbase.com', 'Bank Transfer': 'https://wise.com/send-money'
                };
                var url = urls[method];
                if (url) {
                    showToast('Opening ' + method + ' - redirecting...', 'success');
                    setTimeout(function () { window.open(url, '_blank'); }, 800);
                }
            };

            window.closeAuthModal = function () {
                document.getElementById('authModal').classList.remove('active');
                document.body.style.overflow = '';
            };

            window.buildOptions = function (list) {
                var container = document.getElementById('csOptions');
                if (!container) return;
                container.innerHTML = '';
                if (list.length === 0) { container.innerHTML = '<div class="cs-no-result">No country found</div>'; return; }
                list.forEach(function (c) {
                    var div = document.createElement('div');
                    div.className = 'cs-option' + (c.name === selectedCountry.name ? ' selected' : '');
                    div.innerHTML = '<span class="cs-opt-flag">' + c.flag + '</span>' +
                                    '<span class="cs-opt-name">' + c.name + '</span>' +
                                    '<span class="cs-opt-rate">' + c.symbol + c.rate.toLocaleString() + '/SMS</span>';
                    div.addEventListener('click', function () { window.selectCountry(c); });
                    container.appendChild(div);
                });
            };

            window.selectCountry = function (c) {
                selectedCountry = c;
                document.querySelector('.cs-flag').textContent = c.flag;
                document.querySelector('.cs-name').textContent = c.name;
                document.querySelector('.cs-rate').textContent = c.symbol + c.rate.toLocaleString() + '/SMS';
                window.buildOptions(countries);
                window.closeDropdown();
                window.updateCalculator();
            };

            window.toggleDropdown = function () {
                var dd = document.getElementById('selectDropdown');
                var trigger = document.getElementById('selectTrigger');
                var isOpen = dd.classList.contains('open');
                dd.classList.toggle('open', !isOpen);
                trigger.classList.toggle('open', !isOpen);
            };

            window.closeDropdown = function () {
                document.getElementById('selectDropdown').classList.remove('open');
                document.getElementById('selectTrigger').classList.remove('open');
            };

            window.filterCountries = function (val) {
                window.buildOptions(countries.filter(function (c) { return c.name.toLowerCase().indexOf(val.toLowerCase()) !== -1; }));
            };

            window.updateCalculator = function () {
                var slider = document.getElementById('smsSlider');
                var count = parseInt(slider.value) || 0;
                var c = selectedCountry;
                var discount = count >= 100000 ? 20 : count >= 50000 ? 15 : count >= 25000 ? 10 : count >= 10000 ? 5 : 0;
                var finalCost = (count * c.rate) * (1 - discount / 100);
                document.getElementById('smsCountDisplay').textContent = count.toLocaleString();
                document.getElementById('rateDisplay').textContent = c.symbol + c.rate.toLocaleString() + '/SMS';
                document.getElementById('calcResult').textContent = c.symbol + finalCost.toLocaleString();
                document.getElementById('crb-count').textContent = count.toLocaleString();
                document.getElementById('crb-rate').textContent = c.symbol + c.rate.toLocaleString();
                document.getElementById('crb-discount').textContent = '-' + discount + '%';
            };

            var sliderInput = document.getElementById('smsSlider');
            if (sliderInput) sliderInput.addEventListener('input', window.updateCalculator);

            window.toggleFaq = function (btn) {
                var item = btn.parentElement;
                var isOpen = item.classList.contains('open');
                document.querySelectorAll('.faq-item').forEach(function (i) { i.classList.remove('open'); });
                if (!isOpen) item.classList.add('open');
            };

            window.closePayModal = function () {
                document.getElementById('paymentModal').classList.remove('active');
                document.body.style.overflow = '';
            };

            window.switchTab = function (btn, tab) {
                activeTab = tab;
                document.querySelectorAll('.pay-tab').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                document.querySelectorAll('.pay-tab-content').forEach(function (c) { c.style.display = 'none'; });
                document.getElementById('tab-' + tab).style.display = 'block';
            };

            window.formatCard = function (input) {
                var v = input.value.replace(/\D/g, '').slice(0, 16);
                var parts = [];
                for (var i = 0; i < v.length; i += 4) { parts.push(v.substring(i, i + 4)); }
                input.value = parts.join(' ');
            };

            window.formatExpiry = function (input) {
                var v = input.value.replace(/\D/g, '').slice(0, 4);
                input.value = v.length >= 2 ? v.slice(0, 2) + '/' + v.slice(2) : v;
            };

            window.submitPayment = function () {
                var error = document.getElementById('payError');
                if (error) error.style.display = 'none';

                if (activeTab === 'card') {
                    var name = document.getElementById('cardName').value.trim();
                    var num = document.getElementById('cardNumber').value.replace(/\s/g, '');
                    if (!name || num.length < 16) { error.textContent = 'Check your card details.'; error.style.display = 'block'; return; }
                }

                var btn = document.getElementById('paySubmitBtn');
                btn.disabled = true;
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                var body = 'planName=' + encodeURIComponent(currentPlan) +
                           '&amount=' + encodeURIComponent(currentAmount) +
                           '&billingType=' + encodeURIComponent(isAnnual ? 'Annual' : 'Monthly') +
                           '&cardholderName=' + encodeURIComponent(activeTab === 'card' ? document.getElementById('cardName').value : 'User') +
                           '&cardLastFour=' + encodeURIComponent(document.getElementById('cardNumber').value.slice(-4) || '0000') +
                           '&paymentMethod=' + encodeURIComponent(activeTab);

                fetch('/Order/PlaceOrder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                    body: body
                })
                .then(function (r) { if (!r.ok) throw new Error(r.status); return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        document.getElementById('payStep1').style.display = 'none';
                        document.getElementById('payStep2').style.display = 'block';
                        document.getElementById('successOrderNum').textContent = data.orderNumber;
                        document.getElementById('successPlan').textContent = currentPlan;
                        document.getElementById('successAmount').textContent = document.getElementById('pay-plan-amount').textContent;
                        document.getElementById('successEmail').textContent = data.email;
                    }
                })
                .catch(function (err) {
                    error.textContent = 'Payment Error: ' + err.message;
                    error.style.display = 'block';
                    btn.disabled = false;
                });
            };

            // Custom Bundle Logic
            window.openCustomCreator = function() {
                document.getElementById('creatorModal').style.display = 'flex';
                window.calculateCustomPrice();
            };

            window.closeCustomCreator = function() {
                document.getElementById('creatorModal').style.display = 'none';
            };

            window.calculateCustomPrice = function() {
                var sms = document.getElementById('custSms').value || 0;
                var rate = document.getElementById('custCountry').value;
                var total = sms * rate;
                document.getElementById('custPriceDisplay').textContent = '$' + total.toLocaleString();
            };

                 // Custom Bundle Logic
            window.openCustomCreator = function() {
                document.getElementById('creatorModal').style.display = 'flex';
                window.calculateCustomPrice();
            };

            window.closeCustomCreator = function() {
                document.getElementById('creatorModal').style.display = 'none';
            };

            window.calculateCustomPrice = function() {
                var sms = document.getElementById('custSms').value || 0;
                var rate = document.getElementById('custCountry').value;
                var total = sms * rate;
                document.getElementById('custPriceDisplay').textContent = '$' + total.toLocaleString();
            };

            window.proceedToPayment = function() {
                // 1. Get the price from the display
                var priceText = document.getElementById('custPriceDisplay').textContent;

                // 2. Convert to number for the database (remove $ and commas)
                currentAmount = parseFloat(priceText.replace(/[$,]/g, ""));

                // 3. Get the plan name
                var customName = document.getElementById('custName').value.trim();
                currentPlan = customName ? "Bundle: " + customName : "Custom Bundle";

                // 4. Update the Checkout Modal UI
                document.getElementById('pay-plan-name').textContent = currentPlan;
                document.getElementById('pay-plan-amount').textContent = priceText + (isAnnual ? ' (Annual)' : '/mo');

                // 5. Close Designer and open Payment modal
                window.closeCustomCreator();
                document.getElementById('paymentModal').classList.add('active');
                document.body.style.overflow = 'hidden';
            };

            // Initialize logic
            window.buildOptions(countries);
            window.updateCalculator();

        }()); // This closes the 'use strict' function
    </script>
}