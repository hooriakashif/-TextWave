@{
    ViewData["Title"] = "Home";
    ViewData["ActivePage"] = "Home";
}

<!-- ========== HERO SECTION ========== -->
<section class="hero-section" id="hero">
    <div class="hero-bg-effects">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
        <div class="hero-grid"></div>
    </div>

    <div class="container position-relative">
        <div class="row align-items-center min-vh-100 py-5">

            <!-- Left Content -->
            <div class="col-lg-6 hero-content">
                <div class="animate-fadeInLeft">
                    <div class="tw-badge mb-4">
                        <i class="fas fa-bolt"></i>
                        World's No.1 Bulk SMS Platform
                    </div>
                    <h1 class="hero-title">
                        Send SMS That
                        <span class="gradient-text d-block">Actually Gets</span>
                        <span class="hero-title-outline">Delivered</span>
                    </h1>
                    <p class="hero-subtitle">
                        Power your business with lightning-fast bulk SMS, OTPs,
                        two-way messaging and smart campaigns — reaching
                        <strong style="color:var(--accent-light)">190+ countries</strong>
                        in milliseconds.
                    </p>
                    <div class="hero-cta-group">
                        <a href="/Identity/Account/Register" class="btn-primary-tw">
                            <i class="fas fa-rocket"></i> Start Free Today
                        </a>
                        <a href="/Home/Pricing" class="btn-outline-tw">
                            <i class="fas fa-tag"></i> View Pricing
                        </a>
                    </div>
                    <div class="hero-trust">
                        <div class="hero-trust-item">
                            <i class="fas fa-check-circle"></i>
                            <span>No credit card required</span>
                        </div>
                        <div class="hero-trust-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Free 100 SMS on signup</span>
                        </div>
                        <div class="hero-trust-item">
                            <i class="fas fa-check-circle"></i>
                            <span>99.9% uptime SLA</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Visual -->
            <div class="col-lg-6 hero-visual animate-fadeInRight delay-2">
                <div class="hero-phone-mockup">
                    <div class="phone-glow"></div>
                    <div class="phone-frame">
                        <div class="phone-screen">
                            <div class="phone-header">
                                <div class="phone-signal">
                                    <span></span><span></span><span></span>
                                </div>
                                <span class="phone-carrier">TextWave</span>
                                <i class="fas fa-wifi" style="font-size:0.7rem;color:var(--white);"></i>
                            </div>
                            <div class="phone-messages">
                                <div class="sms-bubble sms-bubble-in animate-fadeInLeft delay-1">
                                    <i class="fas fa-store me-1" style="font-size:0.7rem;"></i>
                                    <strong>TextWave Alert</strong>
                                    <p>Your OTP is <strong style="color:var(--accent-light)">847291</strong>. Valid for 5 mins.</p>
                                </div>
                                <div class="sms-bubble sms-bubble-in animate-fadeInLeft delay-2">
                                    <i class="fas fa-tag me-1" style="font-size:0.7rem;"></i>
                                    <strong>FlashSale</strong>
                                    <p>🔥 50% OFF ends tonight! Use code <strong style="color:var(--accent-light)">WAVE50</strong></p>
                                </div>
                                <div class="sms-bubble sms-bubble-out animate-fadeInRight delay-3">
                                    <p>STOP</p>
                                </div>
                                <div class="sms-bubble sms-bubble-in animate-fadeInLeft delay-4">
                                    <i class="fas fa-calendar me-1" style="font-size:0.7rem;"></i>
                                    <strong>Reminder</strong>
                                    <p>Your appointment is tomorrow at 10:00 AM ✓</p>
                                </div>
                            </div>
                            <div class="phone-stats-bar">
                                <div class="phone-stat">
                                    <span class="phone-stat-num">98.7%</span>
                                    <span class="phone-stat-label">Delivery</span>
                                </div>
                                <div class="phone-stat-divider"></div>
                                <div class="phone-stat">
                                    <span class="phone-stat-num">0.3s</span>
                                    <span class="phone-stat-label">Speed</span>
                                </div>
                                <div class="phone-stat-divider"></div>
                                <div class="phone-stat">
                                    <span class="phone-stat-num">190+</span>
                                    <span class="phone-stat-label">Countries</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="floating-card fc-1 animate-float">
                        <i class="fas fa-paper-plane"></i>
                        <div>
                            <strong>1.2M</strong>
                            <span>SMS sent today</span>
                        </div>
                    </div>
                    <div class="floating-card fc-2 animate-float delay-2">
                        <i class="fas fa-shield-alt"></i>
                        <div>
                            <strong>99.9%</strong>
                            <span>Uptime SLA</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="scroll-indicator">
        <div class="scroll-dot"></div>
    </div>
</section>

<!-- ========== TRUSTED BY ========== -->
<section class="trusted-section">
    <div class="container">
        <p class="trusted-label">Trusted by 5,000+ businesses worldwide</p>
        <div class="trusted-logos">
            <div class="trusted-logo"><i class="fas fa-building me-2"></i>TechCorp</div>
            <div class="trusted-logo"><i class="fas fa-shopping-cart me-2"></i>ShopMax</div>
            <div class="trusted-logo"><i class="fas fa-university me-2"></i>EduLearn</div>
            <div class="trusted-logo"><i class="fas fa-heartbeat me-2"></i>MediCare</div>
            <div class="trusted-logo"><i class="fas fa-plane me-2"></i>TravelGo</div>
            <div class="trusted-logo"><i class="fas fa-chart-line me-2"></i>FinanceHub</div>
        </div>
    </div>
</section>

<!-- ========== STATS ========== -->
<section class="section-padding">
    <div class="container">
        <div class="stats-grid reveal">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-paper-plane"></i></div>
                <div class="stat-number" data-target="5" data-suffix="B+">0</div>
                <div class="stat-label">SMS Delivered</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-globe"></i></div>
                <div class="stat-number" data-target="190" data-suffix="+">0</div>
                <div class="stat-label">Countries Covered</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-number" data-target="50" data-suffix="K+">0</div>
                <div class="stat-label">Happy Customers</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-award"></i></div>
                <div class="stat-number" data-target="99" data-suffix=".9%">0</div>
                <div class="stat-label">Delivery Rate</div>
            </div>
        </div>
    </div>
</section>

<!-- ========== FEATURES ========== -->
<section class="section-padding" id="features">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">Why TextWave</div>
            <h2 class="section-title">Everything You Need to <span>Scale</span></h2>
            <p class="section-subtitle">
                A complete SMS toolkit built for modern businesses.
                From simple alerts to complex campaigns — we handle it all.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6 reveal delay-1">
                <div class="tw-card h-100">
                    <div class="icon-box"><i class="fas fa-bolt" style="color:var(--accent-light);"></i></div>
                    <h5 class="feature-title">Instant Delivery</h5>
                    <p class="feature-desc">Messages delivered in under 0.3 seconds via our direct carrier connections in 190+ countries.</p>
                    <div class="feature-tag"><i class="fas fa-circle" style="font-size:0.4rem;color:#4ade80;"></i> 0.3s avg delivery</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 reveal delay-2">
                <div class="tw-card h-100">
                    <div class="icon-box"><i class="fas fa-code" style="color:var(--accent-light);"></i></div>
                    <h5 class="feature-title">Developer-Friendly API</h5>
                    <p class="feature-desc">RESTful API with SDKs for all major languages. Integrate in under 5 minutes with full documentation.</p>
                    <div class="feature-tag"><i class="fas fa-circle" style="font-size:0.4rem;color:#4ade80;"></i> 5-min integration</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 reveal delay-3">
                <div class="tw-card h-100">
                    <div class="icon-box"><i class="fas fa-comments" style="color:var(--accent-light);"></i></div>
                    <h5 class="feature-title">Two-Way Messaging</h5>
                    <p class="feature-desc">Engage in real conversations. Receive replies, automate responses and build SMS chatbots.</p>
                    <div class="feature-tag"><i class="fas fa-circle" style="font-size:0.4rem;color:#4ade80;"></i> Real-time replies</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 reveal delay-1">
                <div class="tw-card h-100">
                    <div class="icon-box"><i class="fas fa-shield-alt" style="color:var(--accent-light);"></i></div>
                    <h5 class="feature-title">OTP & Verification</h5>
                    <p class="feature-desc">Secure your users with one-time passwords. 128-bit encryption and fraud detection built-in.</p>
                    <div class="feature-tag"><i class="fas fa-circle" style="font-size:0.4rem;color:#4ade80;"></i> Bank-grade security</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 reveal delay-2">
                <div class="tw-card h-100">
                    <div class="icon-box"><i class="fas fa-chart-bar" style="color:var(--accent-light);"></i></div>
                    <h5 class="feature-title">Smart Analytics</h5>
                    <p class="feature-desc">Real-time dashboards with delivery reports, click tracking and campaign performance insights.</p>
                    <div class="feature-tag"><i class="fas fa-circle" style="font-size:0.4rem;color:#4ade80;"></i> Live reporting</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 reveal delay-3">
                <div class="tw-card h-100">
                    <div class="icon-box"><i class="fas fa-clock" style="color:var(--accent-light);"></i></div>
                    <h5 class="feature-title">Smart Scheduling</h5>
                    <p class="feature-desc">Schedule campaigns in advance with timezone-aware delivery and automated drip sequences.</p>
                    <div class="feature-tag"><i class="fas fa-circle" style="font-size:0.4rem;color:#4ade80;"></i> Timezone smart</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== HOW IT WORKS ========== -->
<section class="section-padding how-section">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">Simple Process</div>
            <h2 class="section-title">Up & Running in <span>3 Steps</span></h2>
            <p class="section-subtitle">No complex setup. No long contracts. Start sending in minutes.</p>
        </div>

        <!-- FIX 1: Proper horizontal row with col sizing -->
        <div class="row g-0 align-items-center justify-content-center">
            <div class="col-lg-3 col-md-10 reveal delay-1">
                <div class="how-card">
                    <div class="how-number">01</div>
                    <div class="how-icon"><i class="fas fa-user-plus"></i></div>
                    <h5>Create Your Account</h5>
                    <p>Sign up free in 30 seconds. No credit card needed. Get 100 free SMS credits instantly.</p>
                </div>
            </div>
            <div class="col-lg-1 d-none d-lg-flex justify-content-center reveal delay-2">
                <div class="how-arrow"><i class="fas fa-arrow-right"></i></div>
            </div>
            <div class="col-lg-3 col-md-10 reveal delay-2">
                <div class="how-card how-card-accent">
                    <div class="how-number">02</div>
                    <div class="how-icon"><i class="fas fa-upload"></i></div>
                    <h5>Upload Your Contacts</h5>
                    <p>Import contacts via CSV, Excel or our API. Segment and manage lists with ease.</p>
                </div>
            </div>
            <div class="col-lg-1 d-none d-lg-flex justify-content-center reveal delay-3">
                <div class="how-arrow"><i class="fas fa-arrow-right"></i></div>
            </div>
            <div class="col-lg-3 col-md-10 reveal delay-3">
                <div class="how-card">
                    <div class="how-number">03</div>
                    <div class="how-icon"><i class="fas fa-paper-plane"></i></div>
                    <h5>Send & Track</h5>
                    <p>Craft your message, hit send and watch real-time delivery reports roll in.</p>
                </div>
            </div>
        </div>
    </div>
</section>

