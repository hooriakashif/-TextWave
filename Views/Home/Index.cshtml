@section Styles {
    <style>
        .hero-section {
            min-height: 100vh;
            background: var(--gradient-dark);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .hero-bg-effects {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .hero-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.5;
        }

        .hero-orb-1 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(112,25,61,0.6) 0%, transparent 70%);
            top: -200px;
            right: -100px;
            animation: float 8s ease-in-out infinite;
        }

        .hero-orb-2 {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(180,95,129,0.3) 0%, transparent 70%);
            bottom: -100px;
            left: -100px;
            animation: float 10s ease-in-out infinite reverse;
        }

        .hero-orb-3 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(112,25,61,0.4) 0%, transparent 70%);
            top: 50%;
            left: 40%;
            animation: float 12s ease-in-out infinite;
        }

        .hero-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(180,95,129,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(180,95,129,0.04) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        .hero-title {
            font-size: clamp(2.8rem, 5vw, 4.2rem);
            font-weight: 900;
            color: var(--white);
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .hero-title-outline {
            -webkit-text-stroke: 2px var(--accent);
            color: transparent;
        }

        .hero-subtitle {
            font-size: 1.15rem;
            color: var(--gray-text);
            max-width: 520px;
            line-height: 1.8;
            margin-bottom: 36px;
        }

        .hero-cta-group {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 32px;
        }

        .hero-trust {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
        }

        .hero-trust-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--gray-text);
            font-size: 0.88rem;
        }

            .hero-trust-item i {
                color: #4ade80;
                font-size: 0.85rem;
            }

        .hero-phone-mockup {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        .phone-glow {
            position: absolute;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(180,95,129,0.3) 0%, transparent 70%);
            border-radius: 50%;
            animation: pulse-glow 3s ease-in-out infinite;
        }

        .phone-frame {
            width: 280px;
            background: var(--dark-3);
            border-radius: 36px;
            padding: 12px;
            border: 2px solid rgba(180,95,129,0.3);
            box-shadow: var(--shadow-lg), 0 0 60px rgba(112,25,61,0.4);
            position: relative;
            z-index: 2;
        }

        .phone-screen {
            background: var(--dark-2);
            border-radius: 28px;
            overflow: hidden;
            min-height: 480px;
        }

        .phone-header {
            background: var(--primary-dark);
            padding: 12px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .phone-signal {
            display: flex;
            gap: 3px;
            align-items: flex-end;
        }

            .phone-signal span {
                width: 3px;
                background: var(--white);
                border-radius: 1px;
                opacity: 0.8;
            }

                .phone-signal span:nth-child(1) {
                    height: 6px;
                }

                .phone-signal span:nth-child(2) {
                    height: 9px;
                }

                .phone-signal span:nth-child(3) {
                    height: 12px;
                }

        .phone-carrier {
            color: var(--white);
            font-size: 0.75rem;
            font-weight: 600;
        }

        .phone-messages {
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .sms-bubble {
            background: var(--dark-3);
            border-radius: 14px;
            padding: 10px 14px;
            font-size: 0.75rem;
            border: 1px solid var(--border-color);
            max-width: 90%;
        }

            .sms-bubble strong {
                display: block;
                color: var(--accent-light);
                font-size: 0.7rem;
                margin-bottom: 3px;
            }

            .sms-bubble p {
                color: var(--light-text);
                margin: 0;
                line-height: 1.5;
            }

        .sms-bubble-out {
            align-self: flex-end;
            background: rgba(112,25,61,0.4);
            border-color: rgba(180,95,129,0.3);
        }

            .sms-bubble-out p {
