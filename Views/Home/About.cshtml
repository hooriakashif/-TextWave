@{
    ViewData["Title"] = "About Us";
    ViewData["ActivePage"] = "About";
}

<!-- ========== PAGE HERO ========== -->
<section class="page-hero">
    <div class="container position-relative">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8 animate-fadeInUp">
                <div class="section-tag mb-3">Who We Are</div>
                <h1 class="page-hero-title">
                    Built for Businesses That
                    <span class="gradient-text"> Refuse to Be Ignored</span>
                </h1>
                <p class="page-hero-subtitle">
                    TextWave was born from a simple belief — every business deserves
                    a direct line to its customers, no algorithms, no filters, just pure connection.
                </p>
                <div class="breadcrumb-tw justify-content-center mt-3">
                    <a href="/">Home</a>
                    <i class="fas fa-chevron-right" style="font-size:0.7rem;"></i>
                    <span>About Us</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== STORY SECTION ========== -->
<section class="section-padding">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal">
                <div class="about-visual">
                    <div class="about-visual-card about-vc-1">
                        <i class="fas fa-rocket"></i>
                        <div>
                            <strong>Founded 2018</strong>
                            <span>San Francisco, CA</span>
                        </div>
                    </div>
                    <div class="about-visual-card about-vc-2">
                        <i class="fas fa-globe"></i>
                        <div>
                            <strong>190+ Countries</strong>
                            <span>Global coverage</span>
                        </div>
                    </div>
                    <div class="about-visual-card about-vc-3">
                        <i class="fas fa-users"></i>
                        <div>
                            <strong>50,000+ Clients</strong>
                            <span>Trust TextWave</span>
                        </div>
                    </div>
                    <div class="about-big-number">
                        <span>5B+</span>
                        <p>Messages Delivered</p>
                    </div>
                    <div class="about-orb"></div>
                </div>
            </div>
            <div class="col-lg-6 reveal delay-2">
                <div class="section-tag">Our Story</div>
                <h2 class="section-title">We Started with a <span>Simple Problem</span></h2>
                <p style="color:var(--gray-text);line-height:1.9;margin-bottom:20px;">
                    In 2018, our founders were running a small e-commerce business and
                    struggling with email open rates below 15%. They turned to SMS — and
                    watched engagement soar to 98%. That moment changed everything.
                </p>
                <p style="color:var(--gray-text);line-height:1.9;margin-bottom:32px;">
                    TextWave was built to give every business — from solo entrepreneurs
                    to Fortune 500 companies — the power of direct, instant communication.
                    Today we process over 5 billion messages annually across 190+ countries.
                </p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="about-stat-mini">
                            <i class="fas fa-check-circle"></i>
                            <span>99.9% Uptime SLA</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="about-stat-mini">
                            <i class="fas fa-check-circle"></i>
                            <span>24/7 Expert Support</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="about-stat-mini">
                            <i class="fas fa-check-circle"></i>
                            <span>GDPR Compliant</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="about-stat-mini">
                            <i class="fas fa-check-circle"></i>
                            <span>ISO 27001 Certified</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== MISSION & VISION ========== -->
<section class="section-padding mv-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4 reveal delay-1">
                <div class="mv-card">
                    <div class="mv-icon">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h4>Our Mission</h4>
                    <p>
                        To democratize business communication by making enterprise-grade
                        SMS technology accessible, affordable and powerful for every
                        business on the planet.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 reveal delay-2">
                <div class="mv-card mv-card-featured">
                    <div class="mv-icon">
                        <i class="fas fa-eye"></i>
                    </div>
                    <h4>Our Vision</h4>
                    <p>
                        A world where every business can instantly reach every customer,
                        anywhere, in any language — with messages that matter and
                        conversations that convert.
                    </p>
                </div>
            </div>
            <div class="col-lg-4 reveal delay-3">
                <div class="mv-card">
                    <div class="mv-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h4>Our Values</h4>
                    <p>
                        Reliability, transparency and customer obsession sit at the
                        core of everything we build. We succeed only when our
                        customers succeed.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== TEAM ========== -->
<section class="section-padding">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">The People</div>
            <h2 class="section-title">Meet the <span>Dream Team</span></h2>
            <p class="section-subtitle">
                Passionate engineers, designers and strategists united by one goal —
                making your communication unstoppable.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-3 col-md-6 reveal delay-1">
                <div class="team-card">
                    <div class="team-avatar team-avatar-1">JM</div>
                    <h5 class="team-name">James Morgan</h5>
                    <p class="team-role">CEO & Co-Founder</p>
                    <p class="team-bio">Former Google engineer with 15 years in telecom infrastructure.</p>
                    <div class="team-social">
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 reveal delay-2">
                <div class="team-card">
                    <div class="team-avatar team-avatar-2">SP</div>
                    <h5 class="team-name">Sophia Patel</h5>
                    <p class="team-role">CTO & Co-Founder</p>
                    <p class="team-bio">MIT grad, built SMS gateways used by 200M+ users worldwide.</p>
                    <div class="team-social">
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-github"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 reveal delay-3">
                <div class="team-card">
                    <div class="team-avatar team-avatar-3">MK</div>
                    <h5 class="team-name">Marcus Kim</h5>
                    <p class="team-role">Head of Product</p>
                    <p class="team-bio">Product visionary who shipped 50+ features loved by customers.</p>
                    <div class="team-social">
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 reveal delay-4">
                <div class="team-card">
                    <div class="team-avatar team-avatar-4">AL</div>
                    <h5 class="team-name">Aisha Larsson</h5>
                    <p class="team-role">Head of Customer Success</p>
                    <p class="team-bio">Ensures every client achieves their communication goals.</p>
                    <div class="team-social">
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== ACHIEVEMENTS ========== -->
<section class="section-padding achievements-section">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-tag">Recognition</div>
            <h2 class="section-title">Awards & <span>Achievements</span></h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6 reveal delay-1">
                <div class="award-card">
                    <div class="award-icon"><i class="fas fa-trophy"></i></div>
                    <h6>Best SMS Platform 2024</h6>
                    <span>TechCrunch Awards</span>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 reveal delay-2">
                <div class="award-card">
                    <div class="award-icon"><i class="fas fa-medal"></i></div>
                    <h6>Top 50 SaaS Companies</h6>
                    <span>Forbes Cloud 100</span>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 reveal delay-3">
                <div class="award-card">
                    <div class="award-icon"><i class="fas fa-star"></i></div>
                    <h6>5-Star Customer Rating</h6>
                    <span>G2 & Capterra 2024</span>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 reveal delay-4">
                <div class="award-card">
                    <div class="award-icon"><i class="fas fa-shield-alt"></i></div>
                    <h6>ISO 27001 Certified</h6>
                    <span>Information Security</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== CTA ========== -->
<section class="section-padding-sm">
    <div class="container">
        <div class="cta-box reveal">
            <div class="cta-orb"></div>
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="section-tag mb-3">Join the Wave</div>
                    <h2 class="cta-title">Ready to Be Part of the <span>TextWave Story?</span></h2>
                    <p class="cta-subtitle">Join 50,000+ businesses already transforming how they communicate.</p>
                </div>
                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                    <a href="/Identity/Account/Register" class="btn-primary-tw">
                        <i class="fas fa-rocket"></i> Get Started Free
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        /* ===== PAGE HERO ===== */
        .page-hero {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--dark-3) 50%, var(--dark-2) 100%);
            padding: 140px 0 80px;
            position: relative;
            overflow: hidden;
        }

            .page-hero::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -20%;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(180,95,129,0.12) 0%, transparent 70%);
                border-radius: 50%;
            }

            .page-hero::after {
                content: '';
                position: absolute;
                bottom: -30%;
                left: -10%;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(112,25,61,0.15) 0%, transparent 70%);
                border-radius: 50%;
            }

        .page-hero-title {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 800;
            color: var(--white);
            margin-bottom: 16px;
        }

        .page-hero-subtitle {
            color: var(--gray-text);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.8;
        }

        /* ===== ABOUT VISUAL ===== */
        .about-visual {
            position: relative;
            height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .about-orb {
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(112,25,61,0.3) 0%, transparent 70%);
            border-radius: 50%;
            animation: pulse-glow 4s ease-in-out infinite;
        }

        .about-big-number {
            position: absolute;
            text-align: center;
            z-index: 2;
        }

            .about-big-number span {
                font-family: 'Poppins', sans-serif;
                font-size: 5rem;
                font-weight: 900;
                background: var(--gradient-primary);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                line-height: 1;
                display: block;
            }

            .about-big-number p {
                color: var(--gray-text);
                font-size: 0.9rem;
                margin: 8px 0 0;
            }

        .about-visual-card {
            position: absolute;
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 12px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 3;
            box-shadow: var(--shadow-md);
            animation: float 4s ease-in-out infinite;
        }

            .about-visual-card i {
                color: var(--accent-light);
                font-size: 1.3rem;
            }

            .about-visual-card strong {
                display: block;
                color: var(--white);
                font-size: 0.88rem;
                font-weight: 700;
            }

            .about-visual-card span {
                color: var(--gray-text);
                font-size: 0.75rem;
            }

        .about-vc-1 {
            top: 20px;
            left: 0;
            animation-delay: 0s;
        }

        .about-vc-2 {
            top: 20px;
            right: 0;
            animation-delay: 0.8s;
        }

        .about-vc-3 {
            bottom: 40px;
            left: 20px;
            animation-delay: 1.6s;
        }

        .about-stat-mini {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(180,95,129,0.08);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 12px 16px;
        }

            .about-stat-mini i {
                color: #4ade80;
                font-size: 0.9rem;
            }

            .about-stat-mini span {
                color: var(--light-text);
                font-size: 0.88rem;
                font-weight: 500;
            }

        /* ===== MISSION / VISION ===== */
        .mv-section {
            background: rgba(42,21,32,0.2);
        }

        .mv-card {
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 40px 32px;
            text-align: center;
            height: 100%;
            transition: var(--transition);
        }

            .mv-card:hover {
                transform: translateY(-8px);
                border-color: rgba(180,95,129,0.4);
                box-shadow: var(--shadow-lg);
            }

        .mv-card-featured {
            border-color: rgba(180,95,129,0.5);
            background: linear-gradient(145deg, rgba(112,25,61,0.25), rgba(26,13,19,0.95));
        }

        .mv-icon {
            width: 70px;
            height: 70px;
            background: var(--gradient-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 1.6rem;
            color: var(--white);
            box-shadow: 0 8px 24px rgba(112,25,61,0.4);
        }

        .mv-card h4 {
            color: var(--white);
            font-weight: 700;
            margin-bottom: 16px;
            font-size: 1.3rem;
        }

        .mv-card p {
            color: var(--gray-text);
            line-height: 1.8;
            font-size: 0.95rem;
            margin: 0;
        }

        /* ===== TEAM ===== */
        .team-card {
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 36px 24px;
            text-align: center;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

            .team-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--gradient-primary);
                transform: scaleX(0);
                transition: var(--transition);
            }

            .team-card:hover {
                transform: translateY(-10px);
                border-color: rgba(180,95,129,0.4);
                box-shadow: var(--shadow-lg);
            }

                .team-card:hover::before {
                    transform: scaleX(1);
                }

        .team-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--white);
            border: 3px solid rgba(180,95,129,0.3);
        }

        .team-avatar-1 {
            background: linear-gradient(135deg, #70193D, #B45F81);
        }

        .team-avatar-2 {
            background: linear-gradient(135deg, #4e1129, #8a1f4a);
        }

        .team-avatar-3 {
            background: linear-gradient(135deg, #B45F81, #e8b4c8);
        }

        .team-avatar-4 {
            background: linear-gradient(135deg, #70193D, #c97a97);
        }

        .team-name {
            color: var(--white);
            font-weight: 700;
            font-size: 1.05rem;
            margin-bottom: 4px;
        }

        .team-role {
            color: var(--accent-light);
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 12px;
        }

        .team-bio {
            color: var(--gray-text);
            font-size: 0.88rem;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .team-social {
            display: flex;
            justify-content: center;
            gap: 10px;
        }

            .team-social a {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: rgba(180,95,129,0.1);
                border: 1px solid var(--border-color);
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--accent-light);
                font-size: 0.8rem;
                transition: var(--transition);
            }

                .team-social a:hover {
                    background: var(--gradient-primary);
                    border-color: transparent;
                    color: var(--white);
                    transform: translateY(-2px);
                }

        /* ===== AWARDS ===== */
        .achievements-section {
            background: rgba(42,21,32,0.15);
        }

        .award-card {
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 36px 24px;
            text-align: center;
            transition: var(--transition);
        }

            .award-card:hover {
                transform: translateY(-8px);
                border-color: rgba(180,95,129,0.4);
                box-shadow: var(--shadow-lg);
            }

        .award-icon {
            width: 64px;
            height: 64px;
            background: rgba(180,95,129,0.12);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: var(--accent-light);
            font-size: 1.5rem;
            transition: var(--transition);
        }

        .award-card:hover .award-icon {
            background: var(--gradient-primary);
            color: var(--white);
        }

        .award-card h6 {
            color: var(--white);
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 8px;
        }

        .award-card span {
            color: var(--gray-text);
            font-size: 0.85rem;
        }

        /* ===== CTA (reuse from home) ===== */
        .cta-box {
            background: linear-gradient(135deg, rgba(112,25,61,0.4) 0%, rgba(42,21,32,0.8) 100%);
            border: 1px solid rgba(180,95,129,0.3);
            border-radius: var(--radius-xl);
            padding: 60px;
            position: relative;
            overflow: hidden;
        }

        .cta-orb {
            position: absolute;
            top: -100px;
            right: -100px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(180,95,129,0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

        .cta-title {
            font-size: clamp(1.8rem, 3vw, 2.5rem);
            color: var(--white);
            font-weight: 800;
            margin-bottom: 12px;
        }

            .cta-title span {
                background: var(--gradient-primary);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .cta-subtitle {
            color: var(--gray-text);
            font-size: 1rem;
        }

        @@media (max-width: 768px) {
            .cta-box {
                padding: 36px 24px;
            }

            .about-visual {
                height: 300px;
            }

            .about-big-number span {
                font-size: 3.5rem;
            }
        }
    </style>
}
