            .pp-bottom-primary:hover {
                box-shadow: 0 10px 30px rgba(112,25,61,0.55);
                color: var(--white);
            }
    </style>
}

@section Scripts {
    <script>
        function setActive(el) {
            document.querySelectorAll('.pp-nav-link').forEach(function(a) { a.classList.remove('active'); });
            el.classList.add('active');
        }

        // Auto-highlight sidebar on scroll
        window.addEventListener('scroll', function() {
            var sections = document.querySelectorAll('.pp-section');
            var links = document.querySelectorAll('.pp-nav-link');
            var scrollPos = window.scrollY + 140;
            sections.forEach(function(sec, i) {
                if (sec.offsetTop <= scrollPos && (sec.offsetTop + sec.offsetHeight) > scrollPos) {
                    links.forEach(function(l) { l.classList.remove('active'); });
                    if (links[i]) links[i].classList.add('active');
                }
            });
        });
    </script>
}
