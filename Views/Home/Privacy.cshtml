        }

        .pp-right-card p {
            color: var(--gray-text);
            font-size: 0.8rem;
            margin: 0;
            line-height: 1.6;
        }

        /* CONTACT GRID */
        .pp-contact-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin: 20px 0;
        }

        @@media (max-width: 768px) {
            .pp-contact-grid {
                grid-template-columns: 1fr;
            }
