@{
    ViewData["Title"] = "Privacy Policy";
    ViewData["ActivePage"] = "Privacy";
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="container position-relative">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8 animate-fadeInUp">
                <div class="section-tag mb-3">Legal</div>
                <h1 class="page-hero-title">
                    Privacy <span class="gradient-text">Policy</span>
                </h1>
                <p class="page-hero-subtitle">
                    We take your privacy seriously. This policy explains exactly
                    what data we collect, how we use it and your rights.
                </p>
                <div class="breadcrumb-tw justify-content-center mt-3">
                    <a href="/">Home</a>
                    <i class="fas fa-chevron-right" style="font-size:.7rem"></i>
                    <span>Privacy Policy</span>
                </div>
                <div class="pp-meta-bar">
                    <span><i class="fas fa-calendar-alt"></i> Last updated: March 1, 2025</span>
                    <span><i class="fas fa-clock"></i> 8 min read</span>
                    <span><i class="fas fa-shield-alt"></i> GDPR Compliant</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MAIN CONTENT -->
<section class="section-padding">
    <div class="container">
        <div class="row g-5">

            <!-- Sticky Sidebar -->
            <div class="col-lg-3 d-none d-lg-block">
                <div class="pp-sidebar" id="ppSidebar">
                    <h6 class="pp-sidebar-title">
                        <i class="fas fa-list-ul me-2"></i> Contents
                    </h6>
                    <nav class="pp-nav">
                        <a href="#s1" class="pp-nav-link active" onclick="setActive(this)">1. Introduction</a>
                        <a href="#s2" class="pp-nav-link" onclick="setActive(this)">2. Information We Collect</a>
                        <a href="#s3" class="pp-nav-link" onclick="setActive(this)">3. How We Use Your Data</a>
                        <a href="#s4" class="pp-nav-link" onclick="setActive(this)">4. Data Sharing</a>
                        <a href="#s5" class="pp-nav-link" onclick="setActive(this)">5. Cookies</a>
                        <a href="#s6" class="pp-nav-link" onclick="setActive(this)">6. Data Security</a>
                        <a href="#s7" class="pp-nav-link" onclick="setActive(this)">7. Your Rights</a>
                        <a href="#s8" class="pp-nav-link" onclick="setActive(this)">8. Data Retention</a>
                        <a href="#s9" class="pp-nav-link" onclick="setActive(this)">9. Children's Privacy</a>
                        <a href="#s10" class="pp-nav-link" onclick="setActive(this)">10. Changes to Policy</a>
                        <a href="#s11" class="pp-nav-link" onclick="setActive(this)">11. Contact Us</a>
                    </nav>
                    <div class="pp-sidebar-cta">
                        <i class="fas fa-question-circle"></i>
                        <p>Have questions about your data?</p>
                        <a href="/Home/Contact" class="btn-primary-tw w-100 justify-content-center mt-2" style="font-size:.82rem;padding:10px 16px;">
                            Contact Us
                        </a>
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="col-lg-9">
                <div class="pp-content">

                    <!-- Summary Cards -->
                    <div class="pp-summary-cards">
                        <div class="pp-sum-card">
                            <div class="pp-sum-icon" style="background:linear-gradient(135deg,rgba(74,222,128,0.15),rgba(34,197,94,0.05));border-color:rgba(74,222,128,0.3);">
                                <i class="fas fa-lock" style="color:#4ade80;"></i>
                            </div>
                            <div>
                                <strong>Your data is secure</strong>
                                <span>256-bit SSL encryption on all data</span>
                            </div>
                        </div>
                        <div class="pp-sum-card">
                            <div class="pp-sum-icon" style="background:linear-gradient(135deg,rgba(56,189,248,0.15),rgba(14,165,233,0.05));border-color:rgba(56,189,248,0.3);">
                                <i class="fas fa-ban" style="color:#38bdf8;"></i>
                            </div>
                            <div>
                                <strong>We never sell your data</strong>
                                <span>Your information is never sold to third parties</span>
                            </div>
                        </div>
                        <div class="pp-sum-card">
                            <div class="pp-sum-icon" style="background:linear-gradient(135deg,rgba(251,191,36,0.15),rgba(245,158,11,0.05));border-color:rgba(251,191,36,0.3);">
                                <i class="fas fa-user-check" style="color:#fbbf24;"></i>
                            </div>
                            <div>
                                <strong>You're in control</strong>
                                <span>Access, edit or delete your data anytime</span>
                            </div>
                        </div>
                    </div>

                    <!-- Section 1 -->
                    <div class="pp-section" id="s1">
                        <div class="pp-section-header">
                            <div class="pp-section-num">01</div>
                            <h2 class="pp-section-title">Introduction</h2>
                        </div>
                        <p>Welcome to TextWave ("we," "our," or "us"). We are committed to protecting your personal information and your right to privacy. This Privacy Policy explains how we collect, use, disclose and safeguard your information when you use our SMS marketing platform and related services.</p>
                        <p>By accessing or using our Service, you agree to the terms of this Privacy Policy. If you do not agree with the terms of this Privacy Policy, please do not access the Service.</p>
                        <div class="pp-highlight">
                            <i class="fas fa-info-circle pp-hi-icon"></i>
                            <div>
                                <strong>Plain English Summary</strong>
                                <p>We collect only the data we need to provide you with our SMS platform. We protect it, we do not sell it, and you can delete it anytime.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2 -->
                    <div class="pp-section" id="s2">
                        <div class="pp-section-header">
                            <div class="pp-section-num">02</div>
                            <h2 class="pp-section-title">Information We Collect</h2>
                        </div>
                        <p>We collect information that you provide directly to us, information collected automatically when you use our services, and information from third-party sources.</p>
                        <h4 class="pp-sub">Information You Provide</h4>
                        <div class="pp-list">
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Account Information</strong> — Name, email address, password, company name and phone number when you register.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Payment Information</strong> — Billing address and payment method details (processed securely by our payment providers).</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>SMS Campaign Data</strong> — Phone numbers, message content and contact lists you upload to our platform.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Communications</strong> — Messages you send to our support team or through contact forms.</div>
                            </div>
                        </div>
                        <h4 class="pp-sub">Information Collected Automatically</h4>
                        <div class="pp-list">
                            <div class="pp-list-item">
                                <i class="fas fa-circle" style="color:var(--accent-light);font-size:.5rem;margin-top:6px;"></i>
                                <div><strong>Usage Data</strong> — Pages visited, features used, time spent and actions taken within the platform.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-circle" style="color:var(--accent-light);font-size:.5rem;margin-top:6px;"></i>
                                <div><strong>Device Information</strong> — IP address, browser type, operating system and device identifiers.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-circle" style="color:var(--accent-light);font-size:.5rem;margin-top:6px;"></i>
                                <div><strong>Log Data</strong> — Server logs including access times, error logs and API usage records.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 3 -->
                    <div class="pp-section" id="s3">
                        <div class="pp-section-header">
                            <div class="pp-section-num">03</div>
                            <h2 class="pp-section-title">How We Use Your Data</h2>
                        </div>
                        <p>We use the information we collect to provide, maintain and improve our services. Specifically, we use your data to:</p>
                        <div class="pp-use-grid">
                            <div class="pp-use-card">
                                <i class="fas fa-cog"></i>
                                <h6>Provide Services</h6>
                                <p>Process SMS campaigns, manage your account and deliver the features you pay for.</p>
                            </div>
                            <div class="pp-use-card">
                                <i class="fas fa-shield-alt"></i>
                                <h6>Security</h6>
                                <p>Detect fraud, prevent abuse and protect the security of our platform and users.</p>
                            </div>
                            <div class="pp-use-card">
                                <i class="fas fa-chart-line"></i>
                                <h6>Analytics</h6>
                                <p>Understand how our platform is used to improve features and user experience.</p>
                            </div>
                            <div class="pp-use-card">
                                <i class="fas fa-headset"></i>
                                <h6>Support</h6>
                                <p>Respond to your requests, troubleshoot issues and provide customer support.</p>
                            </div>
                            <div class="pp-use-card">
                                <i class="fas fa-balance-scale"></i>
                                <h6>Legal Compliance</h6>
                                <p>Comply with applicable laws, regulations and legal processes.</p>
                            </div>
                            <div class="pp-use-card">
                                <i class="fas fa-bell"></i>
                                <h6>Communications</h6>
                                <p>Send service updates, security alerts and marketing communications (with consent).</p>
                            </div>
                        </div>
                    </div>

                    <!-- Section 4 -->
                    <div class="pp-section" id="s4">
                        <div class="pp-section-header">
                            <div class="pp-section-num">04</div>
                            <h2 class="pp-section-title">Data Sharing</h2>
                        </div>
                        <p>We do not sell, trade or rent your personal information to third parties. We may share your information only in the following limited circumstances:</p>
                        <div class="pp-list">
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Service Providers</strong> — Trusted third-party companies that help us operate our platform (payment processors, cloud hosting, analytics tools) under strict confidentiality agreements.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Legal Requirements</strong> — When required by law, court order or governmental authority.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Business Transfers</strong> — In connection with a merger, acquisition or sale of all or part of our business, with prior notice to you.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>With Your Consent</strong> — In any other circumstances with your explicit prior consent.</div>
                            </div>
                        </div>
                        <div class="pp-highlight pp-highlight-warn">
                            <i class="fas fa-exclamation-triangle pp-hi-icon" style="color:#fbbf24;"></i>
                            <div>
                                <strong>We Never Sell Your Data</strong>
                                <p>TextWave will never sell, rent or trade your personal data or your SMS contact lists to advertisers, data brokers or any third party for commercial purposes.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Section 5 -->
                    <div class="pp-section" id="s5">
                        <div class="pp-section-header">
                            <div class="pp-section-num">05</div>
                            <h2 class="pp-section-title">Cookies</h2>
                        </div>
                        <p>We use cookies and similar tracking technologies to track activity on our Service and store certain information. You can instruct your browser to refuse all cookies or to indicate when a cookie is being sent.</p>
                        <div class="pp-table-wrap">
                            <table class="pp-table">
                                <thead>
                                    <tr>
                                        <th>Cookie Type</th>
                                        <th>Purpose</th>
                                        <th>Duration</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><span class="pp-tag pp-tag-green">Essential</span></td>
                                        <td>Authentication, security and core platform functionality</td>
                                        <td>Session</td>
                                    </tr>
                                    <tr>
                                        <td><span class="pp-tag pp-tag-blue">Analytics</span></td>
                                        <td>Understanding how users interact with our platform</td>
                                        <td>2 years</td>
                                    </tr>
                                    <tr>
                                        <td><span class="pp-tag pp-tag-yellow">Preferences</span></td>
                                        <td>Remembering your settings and preferences</td>
                                        <td>1 year</td>
                                    </tr>
                                    <tr>
                                        <td><span class="pp-tag pp-tag-pink">Marketing</span></td>
                                        <td>Delivering relevant advertisements (with consent only)</td>
                                        <td>90 days</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Section 6 -->
                    <div class="pp-section" id="s6">
                        <div class="pp-section-header">
                            <div class="pp-section-num">06</div>
                            <h2 class="pp-section-title">Data Security</h2>
                        </div>
                        <p>We implement industry-standard security measures to protect your personal information from unauthorized access, disclosure, alteration and destruction.</p>
                        <div class="pp-security-grid">
                            <div class="pp-sec-item">
                                <i class="fas fa-lock"></i>
                                <span>256-bit SSL Encryption</span>
                            </div>
                            <div class="pp-sec-item">
                                <i class="fas fa-server"></i>
                                <span>Encrypted Data Storage</span>
                            </div>
                            <div class="pp-sec-item">
                                <i class="fas fa-user-shield"></i>
                                <span>Two-Factor Authentication</span>
                            </div>
                            <div class="pp-sec-item">
                                <i class="fas fa-eye-slash"></i>
                                <span>Regular Security Audits</span>
                            </div>
                            <div class="pp-sec-item">
                                <i class="fas fa-network-wired"></i>
                                <span>Intrusion Detection</span>
                            </div>
                            <div class="pp-sec-item">
                                <i class="fas fa-certificate"></i>
                                <span>ISO 27001 Certified</span>
                            </div>
                        </div>
                        <p>While we strive to use commercially acceptable means to protect your personal data, we cannot guarantee its absolute security. No method of transmission over the internet or method of electronic storage is 100% secure.</p>
                    </div>

                    <!-- Section 7 -->
                    <div class="pp-section" id="s7">
                        <div class="pp-section-header">
                            <div class="pp-section-num">07</div>
                            <h2 class="pp-section-title">Your Rights</h2>
                        </div>
                        <p>Depending on your location, you may have the following rights regarding your personal data:</p>
                        <div class="pp-rights-grid">
                            <div class="pp-right-card">
                                <div class="pp-right-icon"><i class="fas fa-eye"></i></div>
                                <h6>Right to Access</h6>
                                <p>Request a copy of all personal data we hold about you.</p>
                            </div>
                            <div class="pp-right-card">
                                <div class="pp-right-icon"><i class="fas fa-edit"></i></div>
                                <h6>Right to Rectify</h6>
                                <p>Correct any inaccurate or incomplete personal data.</p>
                            </div>
                            <div class="pp-right-card">
                                <div class="pp-right-icon"><i class="fas fa-trash-alt"></i></div>
                                <h6>Right to Erasure</h6>
                                <p>Request deletion of your personal data (right to be forgotten).</p>
                            </div>
                            <div class="pp-right-card">
                                <div class="pp-right-icon"><i class="fas fa-hand-paper"></i></div>
                                <h6>Right to Object</h6>
                                <p>Object to processing of your data for marketing purposes.</p>
                            </div>
                            <div class="pp-right-card">
                                <div class="pp-right-icon"><i class="fas fa-download"></i></div>
                                <h6>Data Portability</h6>
                                <p>Receive your data in a structured, machine-readable format.</p>
                            </div>
                            <div class="pp-right-card">
                                <div class="pp-right-icon"><i class="fas fa-pause-circle"></i></div>
                                <h6>Right to Restrict</h6>
                                <p>Request restriction of processing of your personal data.</p>
                            </div>
                        </div>
                        <p>To exercise any of these rights, please contact us at <a href="mailto:privacy@textwave.io" style="color:var(--accent-light);">privacy@textwave.io</a>. We will respond within 30 days.</p>
                    </div>

                    <!-- Section 8 -->
                    <div class="pp-section" id="s8">
                        <div class="pp-section-header">
                            <div class="pp-section-num">08</div>
                            <h2 class="pp-section-title">Data Retention</h2>
                        </div>
                        <p>We retain your personal data only for as long as necessary to fulfil the purposes for which it was collected, including legal, accounting or reporting requirements.</p>
                        <div class="pp-list">
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Account Data</strong> — Retained for the duration of your account plus 90 days after closure.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>SMS Campaign Data</strong> — Retained for 12 months after the campaign is sent, then automatically deleted.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Billing Records</strong> — Retained for 7 years as required by applicable financial regulations.</div>
                            </div>
                            <div class="pp-list-item">
                                <i class="fas fa-check-circle"></i>
                                <div><strong>Log Data</strong> — Server and access logs retained for 90 days for security and debugging purposes.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 9 -->
                    <div class="pp-section" id="s9">
                        <div class="pp-section-header">
                            <div class="pp-section-num">09</div>
                            <h2 class="pp-section-title">Children's Privacy</h2>
                        </div>
                        <p>Our Service is not directed to individuals under the age of 18. We do not knowingly collect personal information from children under 18. If you become aware that a child has provided us with personal information, please contact us immediately.</p>
                        <p>If we become aware that we have collected personal data from a child under 18 without verification of parental consent, we take steps to remove that information from our servers immediately.</p>
                    </div>

                    <!-- Section 10 -->
                    <div class="pp-section" id="s10">
                        <div class="pp-section-header">
                            <div class="pp-section-num">10</div>
                            <h2 class="pp-section-title">Changes to This Policy</h2>
                        </div>
                        <p>We may update this Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page and updating the "Last updated" date at the top.</p>
                        <p>For significant changes, we will provide a more prominent notice, including email notification to the address associated with your account. Your continued use of the Service after the effective date of the revised Privacy Policy constitutes your acceptance of the terms.</p>
                    </div>

                    <!-- Section 11 -->
                    <div class="pp-section" id="s11">
                        <div class="pp-section-header">
                            <div class="pp-section-num">11</div>
                            <h2 class="pp-section-title">Contact Us</h2>
                        </div>
                        <p>If you have any questions about this Privacy Policy or our data practices, please contact us:</p>
                        <div class="pp-contact-grid">
                            <div class="pp-contact-card">
                                <i class="fas fa-envelope"></i>
                                <h6>Email</h6>
                                <a href="mailto:privacy@textwave.io">privacy@textwave.io</a>
                            </div>
                            <div class="pp-contact-card">
                                <i class="fas fa-map-marker-alt"></i>
                                <h6>Address</h6>
                                <span>123 Wave Street, San Francisco, CA 94105</span>
                            </div>
                            <div class="pp-contact-card">
                                <i class="fas fa-clock"></i>
                                <h6>Response Time</h6>
                                <span>Within 30 days of your request</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom nav -->
                    <div class="pp-bottom-nav">
                        <a href="/Home/Terms" class="pp-bottom-btn">
                            <i class="fas fa-file-contract me-2"></i> Read Terms &amp; Conditions
                        </a>
                        <a href="/Home/Contact" class="pp-bottom-btn pp-bottom-primary">
                            <i class="fas fa-envelope me-2"></i> Contact Us About Privacy
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .page-hero {
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--dark-3) 50%, var(--dark-2) 100%);
            padding: 140px 0 80px;
            position: relative;
            overflow: hidden;
        }

            .page-hero::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -20%;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(180,95,129,0.12) 0%, transparent 70%);
                border-radius: 50%;
            }

        .page-hero-title {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 800;
            color: var(--white);
            margin-bottom: 16px;
        }

        .page-hero-subtitle {
            color: var(--gray-text);
            font-size: 1.05rem;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.8;
        }

        .pp-meta-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            margin-top: 28px;
            flex-wrap: wrap;
        }

            .pp-meta-bar span {
                color: var(--gray-text);
                font-size: 0.85rem;
                display: flex;
                align-items: center;
                gap: 7px;
            }

            .pp-meta-bar i {
                color: var(--accent-light);
            }

        /* SIDEBAR */
        .pp-sidebar {
            position: sticky;
            top: 100px;
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 24px;
        }

        .pp-sidebar-title {
            color: var(--white);
            font-size: 0.88rem;
            font-weight: 700;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
        }

        .pp-nav {
            display: flex;
            flex-direction: column;
            gap: 2px;
            margin-bottom: 24px;
        }

        .pp-nav-link {
            color: var(--gray-text);
            font-size: 0.82rem;
            padding: 7px 12px;
            border-radius: 8px;
            transition: var(--transition);
            border-left: 2px solid transparent;
        }

            .pp-nav-link:hover {
                color: var(--accent-light);
                background: rgba(180,95,129,0.08);
                border-left-color: var(--accent);
            }

            .pp-nav-link.active {
                color: var(--accent-light);
                background: rgba(180,95,129,0.1);
                border-left-color: var(--accent);
                font-weight: 600;
            }

        .pp-sidebar-cta {
            background: linear-gradient(135deg, rgba(112,25,61,0.2), rgba(42,21,32,0.5));
            border: 1px solid rgba(180,95,129,0.2);
            border-radius: var(--radius-md);
            padding: 16px;
            text-align: center;
        }

            .pp-sidebar-cta i {
                color: var(--accent-light);
                font-size: 1.5rem;
                margin-bottom: 8px;
                display: block;
            }

            .pp-sidebar-cta p {
                color: var(--gray-text);
                font-size: 0.82rem;
                margin: 0 0 8px;
            }

        /* SUMMARY CARDS */
        .pp-summary-cards {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 48px;
        }

        .pp-sum-card {
            display: flex;
            align-items: center;
            gap: 16px;
            background: var(--gradient-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 16px 20px;
            transition: var(--transition);
        }

            .pp-sum-card:hover {
                border-color: rgba(180,95,129,0.3);
                transform: translateX(4px);
            }

        .pp-sum-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            border: 1px solid;
